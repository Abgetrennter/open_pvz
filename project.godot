; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Open PVZ"
run/main_scene="res://scenes/main/main.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://autoload/EventBus.gd"
DebugService="*res://autoload/DebugService.gd"
SceneRegistry="*res://autoload/SceneRegistry.gd"
MechanicFamilyRegistry="*res://autoload/MechanicFamilyRegistry.gd"
MechanicTypeRegistry="*res://autoload/MechanicTypeRegistry.gd"
MechanicCompilerRegistry="*res://autoload/MechanicCompilerRegistry.gd"
DetectionRegistry="*res://autoload/DetectionRegistry.gd"
TriggerRegistry="*res://autoload/TriggerRegistry.gd"
EffectRegistry="*res://autoload/EffectRegistry.gd"
ControllerRegistry="*res://autoload/ControllerRegistry.gd"
ProjectileMovementRegistry="*res://autoload/ProjectileMovementRegistry.gd"
GameState="*res://autoload/GameState.gd"
VisualCueRegistry="*res://autoload/VisualCueRegistry.gd"
VisualFxRegistry="*res://autoload/VisualFxRegistry.gd"
AudioCueRegistry="*res://autoload/AudioCueRegistry.gd"
VisualProfileRegistry="*res://autoload/VisualProfileRegistry.gd"
AssetRegistry="*res://autoload/AssetRegistry.gd"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="canvas_items"

[physics]

3d/physics_engine="Jolt Physics"
common/physics_ticks_per_second=100

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="mobile"
