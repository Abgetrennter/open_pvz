[resource]
script = ExtResource("1_scenario")
scenario_id = &"level_ground_pressure_v1"
display_name = "Ground Pressure V1"
description = "Formal Phase 6 level template focused on baseline ground pressure and disruption layering."
goals = PackedStringArray("Build a stable frontline against runner and tank pressure.", "Use control and summon tools to keep mixed ground lanes from collapsing.")
battlefield_preset = ExtResource("2_battlefield")
initial_sun = 150
card_defs = [ExtResource("3_card_sunflower"), ExtResource("4_card_shooter"), ExtResource("5_card_wall"), ExtResource("6_card_frost"), ExtResource("7_card_spore")]
wave_defs = [ExtResource("8_wave_ground"), ExtResource("9_wave_disrupt")]
battle_goal = &"all_waves_cleared"
defeat_conditions = PackedStringArray("zombie_reached_goal")
defeat_line_x = 60.0
