[gd_resource type="Resource" script_class="BattleScenario" load_steps=9 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Resource" path="res://data/combat/battlefields/phase6/battlefield_ground_baseline.tres" id="2_battlefield"]
[ext_resource type="Resource" path="res://data/combat/cards/demo/card_sunflower.tres" id="3_card_sunflower"]
[ext_resource type="Resource" path="res://data/combat/cards/demo/card_shooter.tres" id="4_card_shooter"]
[ext_resource type="Resource" path="res://data/combat/cards/demo/card_wall.tres" id="5_card_wall"]
[ext_resource type="Resource" path="res://data/combat/cards/phase6/card_frost_pea.tres" id="6_card_frost"]
[ext_resource type="Resource" path="res://data/combat/cards/phase6/card_spore_summoner.tres" id="7_card_spore"]
