[gd_resource type="Resource" script_class="BattleEnvironmentProfile" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/battle/environment/battle_environment_profile.gd" id="1_profile"]

[resource]
script = ExtResource("1_profile")
profile_id = &"env_day_night_cycle"
initial_conditions = PackedStringArray("day", "sunny")
natural_sun_enabled = true
natural_sun_interval_seconds = 0.8
natural_sun_value = 25
sun_interval_scale = 1.0
sun_value_scale = 1.0
light_level = 1.0
visual_environment_id = &"day_sunny"
audio_environment_id = &"day_sunny"
timeline = [{
"at": 0.0,
"conditions": PackedStringArray("day", "sunny"),
"light_level": 1.0,
"natural_sun_enabled": true,
"visual_environment_id": &"day_sunny",
"audio_environment_id": &"day_sunny"
}, {
"at": 0.8,
"conditions": PackedStringArray("night", "clear"),
"light_level": 0.35,
"natural_sun_enabled": false,
"visual_environment_id": &"night_clear",
"audio_environment_id": &"night_clear"
}, {
"at": 1.6,
"conditions": PackedStringArray("day", "sunny"),
"light_level": 1.0,
"natural_sun_enabled": true,
"visual_environment_id": &"day_sunny",
"audio_environment_id": &"day_sunny"
}]
