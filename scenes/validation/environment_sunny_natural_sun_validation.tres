[gd_resource type="Resource" script_class="BattleScenario" load_steps=7 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Resource" path="res://data/combat/modes/mode_standard_battle.tres" id="2_mode"]
[ext_resource type="Script" path="res://scripts/battle/mode/battle_rule_module.gd" id="3_rule_module"]
[ext_resource type="Resource" path="res://data/combat/environments/env_day_sunny.tres" id="4_env"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="5_rule"]

[sub_resource type="Resource" id="RuleModule_environment"]
script = ExtResource("3_rule_module")
module_id = &"environment.core"
display_name = "Environment Core"
enabled = true
priority = 20
params = {
"environment_profile": ExtResource("4_env")
}
tags = PackedStringArray("rule", "environment")

[sub_resource type="Resource" id="Rule_environment_changed"]
script = ExtResource("5_rule")
rule_id = &"environment_changed"
description = "environment.core should publish environment.changed for sunny profile"
event_name = &"environment.changed"
required_core_values = {
"module_id": &"environment.core",
"profile_id": &"env_day_sunny",
"natural_sun_enabled": true
}

[sub_resource type="Resource" id="Rule_natural_sun_spawned"]
script = ExtResource("5_rule")
rule_id = &"natural_sun_spawned"
description = "sunny environment should spawn natural sun"
event_name = &"sun.spawned"
required_core_values = {
"source_type": &"natural_sun",
"value": 25
}

[sub_resource type="Resource" id="Rule_natural_sun_collected"]
script = ExtResource("5_rule")
rule_id = &"natural_sun_collected"
description = "natural sun should auto collect"
event_name = &"resource.changed"
required_core_values = {
"reason": &"collect",
"resource_id": &"sun",
"delta": 25
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"environment_sunny_natural_sun_validation"
display_name = "Environment Sunny Natural Sun Validation"
description = "Validates environment.core initialization and sunny natural sun generation."
validation_time_limit = 2.0
sun_auto_collect_delay = 0.1
mode_def = ExtResource("2_mode")
mode_rule_modules = [SubResource("RuleModule_environment")]
validation_rules = [SubResource("Rule_environment_changed"), SubResource("Rule_natural_sun_spawned"), SubResource("Rule_natural_sun_collected")]
