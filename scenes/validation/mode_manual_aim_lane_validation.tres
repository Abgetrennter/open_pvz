[gd_resource type="Resource" script_class="BattleScenario" load_steps=12 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Resource" path="res://data/combat/modes/mode_manual_aim_lane_battle.tres" id="2_mode"]
[ext_resource type="Resource" path="res://data/combat/modes/objective_score_1.tres" id="3_objective"]
[ext_resource type="Script" path="res://scripts/battle/card_def.gd" id="4_card_def"]
[ext_resource type="Script" path="res://scripts/battle/card_play_request.gd" id="5_card_request"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="6_rule"]
[ext_resource type="Script" path="res://scripts/battle/mode/battle_mode_input_request.gd" id="7_mode_input"]

[sub_resource type="Resource" id="CardDef_mode_manual_aim"]
script = ExtResource("4_card_def")
card_id = &"mode_manual_aim_shooter_card"
display_name = "Mode Manual Aim Shooter Card"
archetype_id = &"archetype_basic_shooter"
sun_cost = 25
cooldown_seconds = 0.0
placement_tags = PackedStringArray("supports_primary")

[sub_resource type="Resource" id="CardPlayRequest_mode_manual_aim"]
script = ExtResource("5_card_request")
at_time = 0.25
card_id = &"mode_manual_aim_shooter_card"
lane_id = 0
slot_index = 0

[sub_resource type="Resource" id="ModeInputRequest_select_entity"]
script = ExtResource("7_mode_input")
at_time = 0.5
action_name = &"entity_click"
entity_archetype_id = &"archetype_basic_shooter"

[sub_resource type="Resource" id="ModeInputRequest_target_slot"]
script = ExtResource("7_mode_input")
at_time = 0.75
action_name = &"cell_click"
lane_id = 1
slot_index = 2

[sub_resource type="Resource" id="Rule_mode_initialized"]
script = ExtResource("6_rule")
rule_id = &"mode_initialized"
description = "mode host should initialize and resolve the attached manual aim mode definition"
event_name = &"battle.mode_initialized"
required_core_values = {
"mode_id": &"manual_aim_lane_battle",
"rule_module_count": 1,
"has_input_profile": true,
"has_objective_def": true,
"input_profile_id": &"manual_aim",
"objective_id": &"score_1"
}

[sub_resource type="Resource" id="Rule_manual_selection"]
script = ExtResource("6_rule")
rule_id = &"manual_selection"
description = "manual aim mode should accept a scripted entity selection event"
event_name = &"battle.mode_selection_changed"
required_core_values = {
"module_id": &"manual_entity_skill"
}

[sub_resource type="Resource" id="Rule_manual_skill_applied"]
script = ExtResource("6_rule")
rule_id = &"manual_skill_applied"
description = "manual aim mode should convert selection plus target slot click into a manual skill application"
event_name = &"battle.mode_rule_applied"
required_core_values = {
"module_id": &"manual_entity_skill",
"source_event": &"input.action.cell_clicked",
"target_lane_id": 1,
"target_slot_index": 2,
"score_key": &"score",
"score_gain": 1,
"current_score": 1
}

[sub_resource type="Resource" id="Rule_mode_objective_victory"]
script = ExtResource("6_rule")
rule_id = &"mode_objective_victory"
description = "score objective should mark battle victory once the manual skill increments progress to the threshold"
event_name = &"battle.victory"
required_core_values = {
"reason": &"score_threshold"
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"mode_manual_aim_lane_validation"
display_name = "Mode Manual Aim Lane Validation"
description = "Validates that the pilot manual aim mode can place a plant, select the spawned entity, click a target slot, and complete the score objective through the mode layer."
goals = PackedStringArray("Mode host initializes the manual aim mode.", "A spawned entity can be selected through mode input.", "A target slot click can trigger manual skill resolution and battle victory.")
validation_time_limit = 2.0
lane_count = 2
initial_sun = 100
mode_def = ExtResource("2_mode")
objective_override = ExtResource("3_objective")
card_defs = [SubResource("CardDef_mode_manual_aim")]
card_play_requests = [SubResource("CardPlayRequest_mode_manual_aim")]
mode_input_requests = [SubResource("ModeInputRequest_select_entity"), SubResource("ModeInputRequest_target_slot")]
validation_rules = [SubResource("Rule_mode_initialized"), SubResource("Rule_manual_selection"), SubResource("Rule_manual_skill_applied"), SubResource("Rule_mode_objective_victory")]
