[gd_resource type="Resource" script_class="BattleScenario" load_steps=6 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battle_spawn_entry.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="3_rule"]

[sub_resource type="Resource" id="Spawn_trajectory_shooter"]
script = ExtResource("2_spawn")
entity_kind = &"plant"
archetype_id = &"archetype_trajectory_shooter_skeleton"
lane_id = 0
x_position = 160.0
spawn_overrides = {
"damage": 20,
"interval": 0.5,
"scan_range": 900.0,
"speed": 320.0
}

[sub_resource type="Resource" id="Spawn_target_dummy"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_lane_dummy"
entity_template_id = &"zombie_lane_dummy"
lane_id = 0
x_position = 800.0
spawn_overrides = {
"max_health": 40
}

[sub_resource type="Resource" id="Rule_trajectory_spawned"]
script = ExtResource("3_rule")
rule_id = &"trajectory_spawned"
description = "trajectory shooter should spawn with archetype identity"
event_name = &"entity.spawned"
required_core_values = {
"target_archetype_id": &"archetype_trajectory_shooter_skeleton",
"target_kind": &"plant"
}

[sub_resource type="Resource" id="Rule_trajectory_hit"]
script = ExtResource("3_rule")
rule_id = &"trajectory_hit"
description = "trajectory mechanic should inject movement_mode into effect_params and the projectile should hit"
event_name = &"projectile.hit"
required_core_values = {
"source_archetype_id": &"archetype_trajectory_shooter_skeleton",
"target_template_id": &"zombie_lane_dummy"
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"trajectory_compile_validation"
display_name = "Trajectory Compile Validation"
description = "Validates that an independent Trajectory mechanic compiles movement_mode into effect_params and the projectile hits the target."
goals = PackedStringArray("Verify the Trajectory mechanic injects movement_mode into the compiled binding effect_params.", "Verify the projectile spawns and hits the target.")
validation_time_limit = 3.0
validation_rules = [SubResource("Rule_trajectory_spawned"), SubResource("Rule_trajectory_hit")]
spawns = [SubResource("Spawn_trajectory_shooter"), SubResource("Spawn_target_dummy")]
