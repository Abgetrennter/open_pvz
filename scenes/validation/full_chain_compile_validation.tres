[gd_resource type="Resource" script_class="BattleScenario" load_steps=6 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battle_spawn_entry.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="3_rule"]

[sub_resource type="Resource" id="Spawn_full_chain_shooter"]
script = ExtResource("2_spawn")
entity_kind = &"plant"
archetype_id = &"archetype_full_chain_shooter_skeleton"
lane_id = 0
x_position = 160.0
spawn_overrides = {
"damage": 20,
"interval": 0.5,
"scan_range": 900.0,
"speed": 320.0
}

[sub_resource type="Resource" id="Spawn_target_dummy"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_lane_dummy"
lane_id = 0
x_position = 800.0
spawn_overrides = {
"max_health": 80
}

[sub_resource type="Resource" id="Rule_full_chain_spawned"]
script = ExtResource("3_rule")
rule_id = &"full_chain_spawned"
description = "full chain archetype should spawn with all 6 family mechanics"
event_name = &"entity.spawned"
required_core_values = {
"target_archetype_id": &"archetype_full_chain_shooter_skeleton",
"target_kind": &"plant"
}

[sub_resource type="Resource" id="Rule_full_chain_hit"]
script = ExtResource("3_rule")
rule_id = &"full_chain_hit"
description = "full chain (Trigger+Targeting+Trajectory+HitPolicy+Emission+Payload) should produce burst projectile hits"
event_name = &"projectile.hit"
required_core_values = {
"source_archetype_id": &"archetype_full_chain_shooter_skeleton",
"target_archetype_id": &"archetype_lane_dummy"
}
min_count = 2

[resource]
script = ExtResource("1_scenario")
scenario_id = &"full_chain_compile_validation"
display_name = "Full Chain Compile Validation"
description = "Validates that an archetype with all 6 attack-chain family mechanics compiles and executes correctly."
goals = PackedStringArray("Verify Trigger + Targeting + Trajectory + HitPolicy + Emission + Payload all compile into a single RuntimeTriggerSpec.", "Verify burst projectiles spawn and hit the target.")
validation_time_limit = 3.0
validation_rules = [SubResource("Rule_full_chain_spawned"), SubResource("Rule_full_chain_hit")]
spawns = [SubResource("Spawn_full_chain_shooter"), SubResource("Spawn_target_dummy")]
