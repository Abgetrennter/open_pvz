[gd_resource type="Resource" script_class="BattleScenario" load_steps=11 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battle_spawn_entry.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="3_rule"]
[ext_resource type="Resource" path="res://data/combat/height_bands/ground_unit.tres" id="4_ground_height"]
[ext_resource type="Resource" path="res://data/combat/projectile_profiles/parabola_arc.tres" id="5_parabola_profile"]

[sub_resource type="Resource" id="Spawn_bomber_plant"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_melon_lobber"
entity_template_id = &"plant_melon_lobber"
lane_id = 0
x_position = 160.0
projectile_flight_profile_override = ExtResource("5_parabola_profile")
spawn_overrides = {
"damage": 18,
"interval": 0.25,
"on_hit_effect_id": &"explode",
"on_hit_effect_params": {
"amount": 18,
"radius": 90.0,
"target_mode": &"enemies_in_radius"
},
"speed": 220.0,
"travel_duration": 0.8
}

[sub_resource type="Resource" id="Spawn_primary_target"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_lane_dummy"
entity_template_id = &"zombie_lane_dummy"
lane_id = 0
x_position = 520.0
spawn_overrides = {
"move_speed": 0.0
}

[sub_resource type="Resource" id="Spawn_secondary_target"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_lane_dummy"
entity_template_id = &"zombie_lane_dummy"
lane_id = 0
x_position = 590.0
spawn_overrides = {
"move_speed": 0.0
}

[sub_resource type="Resource" id="Rule_spawn"]
script = ExtResource("3_rule")
rule_id = &"terminal_spawn"
description = "terminal parabola projectile profile should spawn"
event_name = &"projectile.spawned"
required_tags = PackedStringArray("projectile")
required_core_values = {
"profile_id": &"parabola_arc"
}

[sub_resource type="Resource" id="Rule_terminal_hit"]
script = ExtResource("3_rule")
rule_id = &"terminal_hit"
description = "parabola projectile should resolve a terminal hit before the explosion effect fires"
event_name = &"projectile.hit"
required_tags = PackedStringArray("projectile")
required_core_values = {
"profile_id": &"parabola_arc",
"terminal_reason": &"movement_complete"
}

[sub_resource type="Resource" id="Rule_explode_damage"]
script = ExtResource("3_rule")
rule_id = &"terminal_explode_damage"
description = "terminal explosion should damage both clustered targets in the blast radius"
event_name = &"entity.damaged"
min_count = 2
required_tags = PackedStringArray("explode", "projectile.hit")
required_core_values = {
"target_kind": &"zombie",
"target_lane": 0
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"terminal_explode_validation"
display_name = "Terminal Explode Validation"
description = "Validates that a terminal-hit projectile can hand off to an explode effect and damage clustered enemies at the impact point."
goals = PackedStringArray("Verify terminal hit strategies still emit projectile.hit before effect execution.", "Verify a custom on-hit explode effect can be declared from scenario content.", "Verify clustered targets take explode-tagged damage at the terminal impact point.")
validation_time_limit = 1.8
validation_rules = [SubResource("Rule_spawn"), SubResource("Rule_terminal_hit"), SubResource("Rule_explode_damage")]
spawns = [SubResource("Spawn_bomber_plant"), SubResource("Spawn_primary_target"), SubResource("Spawn_secondary_target")]

