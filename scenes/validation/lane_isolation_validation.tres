[gd_resource type="Resource" script_class="BattleScenario" load_steps=14 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battle_spawn_entry.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="3_rule"]
[ext_resource type="Resource" path="res://data/combat/height_bands/ground_unit.tres" id="4_ground_height"]
[ext_resource type="Resource" path="res://data/combat/projectile_profiles/parabola_arc.tres" id="5_parabola_profile"]

[sub_resource type="Resource" id="Spawn_lane0_plant"]
script = ExtResource("2_spawn")
entity_kind = &"plant"
lane_id = 0
x_position = 160.0
hit_height_band = ExtResource("4_ground_height")
projectile_flight_profile = ExtResource("5_parabola_profile")
params = {
"arc_height": 180.0,
"damage": 20,
"interval": 1.3,
"movement_mode": &"parabola",
"speed": 220.0,
"travel_duration": 1.4
}

[sub_resource type="Resource" id="Spawn_lane0_target"]
script = ExtResource("2_spawn")
entity_kind = &"zombie"
lane_id = 0
x_position = 560.0
hit_height_band = ExtResource("4_ground_height")

[sub_resource type="Resource" id="Spawn_lane1_crossing"]
script = ExtResource("2_spawn")
entity_kind = &"zombie"
lane_id = 1
x_position = 360.0
hit_height_band = ExtResource("4_ground_height")

[sub_resource type="Resource" id="Rule_spawn"]
script = ExtResource("3_rule")
rule_id = &"parabola_spawn"
description = "parabola projectile profile should spawn"
event_name = &"projectile.spawned"
required_tags = PackedStringArray("projectile")
required_core_values = {
"profile_id": &"parabola_arc"
}

[sub_resource type="Resource" id="Rule_lane0_hit"]
script = ExtResource("3_rule")
rule_id = &"lane0_hit"
description = "parabola projectile should hit the in-lane target"
event_name = &"projectile.hit"
required_tags = PackedStringArray("projectile")
required_core_values = {
"profile_id": &"parabola_arc",
"target_lane": 0
}

[sub_resource type="Resource" id="Rule_lane1_hit_blocked"]
script = ExtResource("3_rule")
rule_id = &"lane1_hit_blocked"
description = "parabola projectile should not hit the off-lane blocker"
event_name = &"projectile.hit"
min_count = 0
max_count = 0
required_tags = PackedStringArray("projectile")
required_core_values = {
"profile_id": &"parabola_arc",
"target_lane": 1
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"lane_isolation_validation"
display_name = "Lane Isolation Validation"
description = "Validates that same-flight projectiles continue to honor lane isolation even when their projected screen path crosses another lane."
goals = PackedStringArray("Verify lane metadata is present on validation events.", "Verify off-lane blockers do not intercept parabola projectiles.", "Verify the in-lane target still receives the terminal hit.")
validation_time_limit = 5.0
validation_rules = [SubResource("Rule_spawn"), SubResource("Rule_lane0_hit"), SubResource("Rule_lane1_hit_blocked")]
spawns = [SubResource("Spawn_lane0_plant"), SubResource("Spawn_lane0_target"), SubResource("Spawn_lane1_crossing")]
