[resource]
script = ExtResource("1_scenario")
scenario_id = &"original_explosion_garden_validation"
display_name = "Original Explosion Garden Validation"
description = "Showcase: cherrybomb, jalapeno, doomshroom and potatomine demonstrating various explosion effects."
goals = PackedStringArray("Visual showcase of all original explosion plants in action.")
validation_time_limit = 6.0
lane_count = 4
validation_rules = [SubResource("Rule_tick")]
spawns = [SubResource("Spawn_cherrybomb"), SubResource("Spawn_walker_lane0a"), SubResource("Spawn_walker_lane0b"), SubResource("Spawn_jalapeno"), SubResource("Spawn_runner_lane1"), SubResource("Spawn_doomshroom"), SubResource("Spawn_tank_lane2"), SubResource("Spawn_potatomine"), SubResource("Spawn_walker_lane3")]
