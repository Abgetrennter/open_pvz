[sub_resource type="Resource" id="Rule_cherry_damage"]
script = ExtResource("3_rule")
rule_id = &"cherrybomb_area_damage"
description = "Cherry Bomb should damage a nearby target after card placement."
event_name = &"entity.damaged"
required_tags = PackedStringArray("explode")
required_core_values = {
"source_archetype_id": &"archetype_original_cherrybomb",
"target_archetype_id": &"archetype_basic_walker",
"target_lane": 0
}

[sub_resource type="Resource" id="Rule_jalapeno_damage"]
script = ExtResource("3_rule")
rule_id = &"jalapeno_lane_damage"
