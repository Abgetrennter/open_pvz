[resource]
script = ExtResource("1_scenario")
scenario_id = &"original_explosion_garden_validation"
display_name = "Original Explosion Garden Validation"
description = "Showcase: cherrybomb, jalapeno, doomshroom and potatomine demonstrating placement-triggered and armed explosion effects."
goals = PackedStringArray("Visual showcase of original explosion plants using their real trigger paths.")
validation_time_limit = 20.0
initial_sun = 2000
lane_count = 4
card_defs = [ExtResource("5_cherry_card"), ExtResource("6_jalapeno_card"), ExtResource("7_doom_card")]
card_play_requests = [SubResource("Req_cherrybomb"), SubResource("Req_jalapeno"), SubResource("Req_doomshroom")]
validation_rules = [SubResource("Rule_cherry_damage"), SubResource("Rule_jalapeno_damage"), SubResource("Rule_doom_damage"), SubResource("Rule_potato_armed"), SubResource("Rule_potato_damage"), SubResource("Rule_cherry_kill"), SubResource("Rule_jalapeno_kill"), SubResource("Rule_doom_kill"), SubResource("Rule_potato_kill")]
spawns = [SubResource("Spawn_cherry_target"), SubResource("Spawn_jalapeno_target"), SubResource("Spawn_doom_target"), SubResource("Spawn_potatomine"), SubResource("Spawn_potato_target")]
