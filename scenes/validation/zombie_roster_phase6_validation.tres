[gd_resource type="Resource" script_class="BattleScenario" load_steps=11 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battle_spawn_entry.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="3_rule"]

[sub_resource type="Resource" id="Spawn_wall_barrier"]
script = ExtResource("2_spawn")
entity_template_id = &"plant_wall_barrier"
lane_id = 0
x_position = 200.0

[sub_resource type="Resource" id="Spawn_bone_thrower"]
script = ExtResource("2_spawn")
entity_template_id = &"zombie_bone_thrower"
lane_id = 0
x_position = 500.0

[sub_resource type="Resource" id="Spawn_tar_spitter"]
script = ExtResource("2_spawn")
entity_template_id = &"zombie_tar_spitter"
lane_id = 0
x_position = 620.0

[sub_resource type="Resource" id="Rule_bone_projectile"]
script = ExtResource("3_rule")
rule_id = &"phase6_zombie_bone_attack"
description = "bone thrower should fire a ranged projectile through the shared zombie attack chain"
event_name = &"projectile.spawned"
required_tags = PackedStringArray("projectile")
required_core_values = {
"source_template_id": &"zombie_bone_thrower"
}

[sub_resource type="Resource" id="Rule_bone_damage"]
script = ExtResource("3_rule")
rule_id = &"phase6_zombie_bone_damage"
description = "bone thrower ranged projectiles should damage a defended plant"
event_name = &"entity.damaged"
required_core_values = {
"source_template_id": &"zombie_bone_thrower",
"target_template_id": &"plant_wall_barrier"
}

[sub_resource type="Resource" id="Rule_tar_status"]
script = ExtResource("3_rule")
rule_id = &"phase6_zombie_tar_status"
description = "tar spitter should apply jammed to a defended plant through the shared status effect chain"
event_name = &"entity.status_applied"
required_core_values = {
"source_template_id": &"zombie_tar_spitter",
"status_id": &"jammed",
"target_template_id": &"plant_wall_barrier"
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"zombie_roster_phase6_validation"
display_name = "Zombie Roster Phase 6 Validation"
description = "Validates the first formal Phase 6 zombie roster additions for ranged special attack and support disruption."
goals = PackedStringArray("Verify a ranged zombie can attack backward through shared lane detection and projectile runtime.", "Verify a support zombie can apply jammed through the built-in status effect chain.", "Verify these units work against defended plants without battle-specific special cases.")
validation_time_limit = 6.5
validation_rules = [SubResource("Rule_bone_projectile"), SubResource("Rule_bone_damage"), SubResource("Rule_tar_status")]
spawns = [SubResource("Spawn_wall_barrier"), SubResource("Spawn_bone_thrower"), SubResource("Spawn_tar_spitter")]
