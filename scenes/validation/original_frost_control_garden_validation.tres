[gd_resource type="Resource" script_class="BattleScenario" load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battle_spawn_entry.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="3_rule"]

[sub_resource type="Resource" id="Spawn_snowpea"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_original_snowpea"
lane_id = 0
x_position = 160.0

[sub_resource type="Resource" id="Spawn_walker_lane0"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_basic_walker"
lane_id = 0
x_position = 500.0
spawn_overrides = {
"move_speed": 0.0
}

[sub_resource type="Resource" id="Spawn_frost_pea"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_frost_pea"
lane_id = 1
x_position = 160.0

[sub_resource type="Resource" id="Spawn_walker_lane1"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_basic_walker"
lane_id = 1
x_position = 500.0
spawn_overrides = {
"move_speed": 0.0
}

[sub_resource type="Resource" id="Spawn_snowpea_fast"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_original_snowpea"
lane_id = 2
x_position = 160.0
spawn_overrides = {
"interval": 0.8,
"speed": 300.0
}

[sub_resource type="Resource" id="Spawn_runner_lane2"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_brisk_runner"
lane_id = 2
x_position = 500.0
spawn_overrides = {
"move_speed": 0.0
}

[sub_resource type="Resource" id="Rule_tick"]
script = ExtResource("3_rule")
rule_id = &"tick"
description = "at least one game tick"
event_name = &"game.tick"

[resource]
script = ExtResource("1_scenario")
scenario_id = &"original_frost_control_garden_validation"
display_name = "Original Frost Control Garden Validation"
description = "Showcase: snowpea and frost_pea demonstrating slow and freeze control against ground targets. Note: cactus/iceshroom/cattail/wintermelon excluded due to air-tracking mismatch, sleep-state prerequisite, upgrade dependency or air-height band issues."
goals = PackedStringArray("Visual showcase of frost and control plants that work with direct spawn.")
validation_time_limit = 10.0
lane_count = 3
validation_rules = [SubResource("Rule_tick")]
spawns = [SubResource("Spawn_snowpea"), SubResource("Spawn_walker_lane0"), SubResource("Spawn_frost_pea"), SubResource("Spawn_walker_lane1"), SubResource("Spawn_snowpea_fast"), SubResource("Spawn_runner_lane2")]
