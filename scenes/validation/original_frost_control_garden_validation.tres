[resource]
script = ExtResource("1_scenario")
scenario_id = &"original_frost_control_garden_validation"
display_name = "Original Frost Control Garden Validation"
description = "Showcase: snowpea, wintermelon, iceshroom, cactus and cattail demonstrating slow, freeze, pierce and tracking control abilities."
goals = PackedStringArray("Visual showcase of all original frost and control plants in action.")
validation_time_limit = 10.0
lane_count = 5
validation_rules = [SubResource("Rule_tick")]
spawns = [SubResource("Spawn_snowpea"), SubResource("Spawn_walker_lane0"), SubResource("Spawn_wintermelon"), SubResource("Spawn_walker_lane1"), SubResource("Spawn_runner_lane1"), SubResource("Spawn_iceshroom"), SubResource("Spawn_walker_lane2"), SubResource("Spawn_cactus"), SubResource("Spawn_walker_lane3"), SubResource("Spawn_cattail"), SubResource("Spawn_walker_lane4")]
