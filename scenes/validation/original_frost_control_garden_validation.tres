[sub_resource type="Resource" id="Rule_snowpea_slow"]
script = ExtResource("5_rule")
rule_id = &"snowpea_slow"
description = "Snow Pea should apply slowed status to a ground target."
event_name = &"entity.status_applied"
required_core_values = {
"source_archetype_id": &"archetype_original_snowpea",
"status_id": &"slowed",
"target_archetype_id": &"archetype_basic_walker"
}

[sub_resource type="Resource" id="Rule_iceshroom_damage"]
script = ExtResource("5_rule")
rule_id = &"iceshroom_damage"
description = "Ice-shroom should damage a nearby target through placement."
event_name = &"entity.damaged"
required_tags = PackedStringArray("explode")
required_core_values = {
"source_archetype_id": &"archetype_original_iceshroom",
"target_archetype_id": &"archetype_basic_walker",
"target_lane": 1
}

[sub_resource type="Resource" id="Rule_cactus_air_damage"]
script = ExtResource("5_rule")
rule_id = &"cactus_air_damage"
description = "Cactus should damage an air target."
event_name = &"entity.damaged"
required_core_values = {
"source_archetype_id": &"archetype_original_cactus",
"target_archetype_id": &"archetype_air_scout",
"target_lane": 2
}

[sub_resource type="Resource" id="Rule_winter_accept"]
script = ExtResource("5_rule")
rule_id = &"wintermelon_upgrade_accept"
description = "Winter Melon should replace Melon-pult through entity.replaced."
event_name = &"entity.replaced"
required_core_values = {
"reason": &"upgrade_replacement",
"replaced_archetype_id": &"archetype_original_melonpult",
"replaced_role": &"primary",
"replacement_archetype_id": &"archetype_original_wintermelon",
"replacement_role": &"upgrade"
}

[sub_resource type="Resource" id="Rule_winter_splash"]
script = ExtResource("5_rule")
rule_id = &"wintermelon_splash"
description = "Winter Melon should deal splash damage to clustered targets."
event_name = &"entity.damaged"
min_count = 2
required_tags = PackedStringArray("explode", "projectile.hit")
required_core_values = {
"source_archetype_id": &"archetype_original_wintermelon",
"target_lane": 3
}

[sub_resource type="Resource" id="Rule_cattail_accept"]
script = ExtResource("5_rule")
rule_id = &"cattail_lilypad_upgrade_accept"
description = "Cattail should replace Lily Pad through entity.replaced."
event_name = &"entity.replaced"
required_core_values = {
"reason": &"upgrade_replacement",
"replaced_archetype_id": &"archetype_original_lilypad",
"replaced_role": &"support",
"replacement_archetype_id": &"archetype_original_cattail",
"replacement_role": &"upgrade"
}

[sub_resource type="Resource" id="Rule_cattail_air_damage"]
script = ExtResource("5_rule")
rule_id = &"cattail_air_damage"
description = "Cattail should damage a tracked target after Lily Pad upgrade placement."
event_name = &"entity.damaged"
required_tags = PackedStringArray("projectile.hit")
required_core_values = {
"source_archetype_id": &"archetype_original_cattail"
}

[sub_resource type="Resource" id="Rule_snowpea_kill"]
script = ExtResource("5_rule")
rule_id = &"snowpea_kill"
description = "Snow Pea should eventually kill its slowed ground target."
event_name = &"entity.died"
required_core_values = {
"source_archetype_id": &"archetype_original_snowpea",
"target_archetype_id": &"archetype_basic_walker",
"target_lane": 0
}

[sub_resource type="Resource" id="Rule_iceshroom_kill"]
script = ExtResource("5_rule")
rule_id = &"iceshroom_kill"
description = "Ice-shroom should kill its nearby placement target."
event_name = &"entity.died"
required_core_values = {
"source_archetype_id": &"archetype_original_iceshroom",
"target_archetype_id": &"archetype_basic_walker",
"target_lane": 1
}

[sub_resource type="Resource" id="Rule_cactus_air_kill"]
script = ExtResource("5_rule")
rule_id = &"cactus_air_kill"
description = "Cactus should eventually kill the air target."
event_name = &"entity.died"
required_core_values = {
"source_archetype_id": &"archetype_original_cactus",
"target_archetype_id": &"archetype_air_scout",
"target_lane": 2
}

[sub_resource type="Resource" id="Rule_wintermelon_kill"]
script = ExtResource("5_rule")
rule_id = &"wintermelon_kill"
description = "Winter Melon should eventually kill at least one clustered target."
event_name = &"entity.died"
required_core_values = {
"source_archetype_id": &"archetype_original_wintermelon",
"target_lane": 3
}

[sub_resource type="Resource" id="Rule_cattail_kill"]
script = ExtResource("5_rule")
rule_id = &"cattail_kill"
description = "Cattail should eventually kill a tracked target during an extended run."
event_name = &"entity.died"
required_core_values = {
"source_archetype_id": &"archetype_original_cattail"
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"original_frost_control_garden_validation"
display_name = "Original Frost Control Garden Validation"
description = "Showcase: snowpea, iceshroom, cactus, wintermelon and cattail demonstrating slow, freeze, air targeting, splash slow and tracking through their required contexts."
goals = PackedStringArray("Visual showcase of original frost and control plants using ground, air, water and upgrade prerequisites.")
validation_time_limit = 90.0
initial_sun = 3000
lane_count = 5
board_slot_configs = [SubResource("Water_slot")]
card_defs = [ExtResource("6_ice_card"), ExtResource("7_melon_card"), ExtResource("8_winter_card"), ExtResource("9_lily_card"), ExtResource("10_cattail_card")]
card_play_requests = [SubResource("Req_iceshroom"), SubResource("Req_melon"), SubResource("Req_winter"), SubResource("Req_lily"), SubResource("Req_cattail")]
validation_rules = [SubResource("Rule_snowpea_slow"), SubResource("Rule_iceshroom_damage"), SubResource("Rule_cactus_air_damage"), SubResource("Rule_winter_accept"), SubResource("Rule_winter_splash"), SubResource("Rule_cattail_accept"), SubResource("Rule_cattail_air_damage"), SubResource("Rule_snowpea_kill"), SubResource("Rule_iceshroom_kill"), SubResource("Rule_cactus_air_kill"), SubResource("Rule_wintermelon_kill"), SubResource("Rule_cattail_kill")]
spawns = [SubResource("Spawn_snowpea"), SubResource("Spawn_snowpea_target"), SubResource("Spawn_ice_target"), SubResource("Spawn_cactus"), SubResource("Spawn_cactus_air_target"), SubResource("Spawn_winter_target_a"), SubResource("Spawn_winter_target_b"), SubResource("Spawn_cattail_air_target")]
