[resource]
script = ExtResource("1_scenario")
scenario_id = &"original_defense_support_garden_validation"
display_name = "Original Defense Support Garden Validation"
description = "Showcase: wallnut, tallnut, pumpkin, spikeweed, spikerock and torchwood demonstrating defense and support abilities."
goals = PackedStringArray("Visual showcase of all original defense and support plants in action.")
validation_time_limit = 10.0
lane_count = 5
validation_rules = [SubResource("Rule_tick")]
spawns = [SubResource("Spawn_wallnut"), SubResource("Spawn_walker_lane0"), SubResource("Spawn_tallnut"), SubResource("Spawn_tank_lane1"), SubResource("Spawn_pumpkin"), SubResource("Spawn_walker_lane2"), SubResource("Spawn_spikeweed"), SubResource("Spawn_walker_lane3"), SubResource("Spawn_spikerock"), SubResource("Spawn_tank_lane4")]
