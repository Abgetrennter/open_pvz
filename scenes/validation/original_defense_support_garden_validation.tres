}

[sub_resource type="Resource" id="Rule_spikeweed_damage"]
script = ExtResource("4_rule")
rule_id = &"spikerock_ground_damage"
description = "Spikerock should deal ground damage after replacing Spikeweed."
event_name = &"entity.damaged"
required_tags = PackedStringArray("ground_damage")
required_core_values = {
"source_archetype_id": &"archetype_original_spikerock",
"target_lane": 3
}

[sub_resource type="Resource" id="Rule_spikerock_accept"]
script = ExtResource("4_rule")
rule_id = &"spikerock_upgrade_accept"
description = "Spikerock should replace Spikeweed through entity.replaced."
event_name = &"entity.replaced"
required_core_values = {
"reason": &"upgrade_replacement",
"replaced_archetype_id": &"archetype_original_spikeweed",
"replaced_role": &"primary",
"replacement_archetype_id": &"archetype_original_spikerock",
"replacement_role": &"upgrade"
}

[sub_resource type="Resource" id="Rule_torchwood_combo"]
script = ExtResource("4_rule")
rule_id = &"torchwood_combo_damage"
description = "Peashooter behind Torchwood should damage a target through the support lane."
event_name = &"entity.damaged"
required_core_values = {
"source_archetype_id": &"archetype_original_peashooter",
"target_archetype_id": &"archetype_basic_walker",
"target_lane": 4
}

[sub_resource type="Resource" id="Rule_spikeweed_kill"]
script = ExtResource("4_rule")
rule_id = &"spikerock_ground_kill"
description = "Spikerock should eventually kill its nearby ground target."
event_name = &"entity.died"
required_core_values = {
"source_archetype_id": &"archetype_original_spikerock",
"target_archetype_id": &"archetype_basic_walker",
"target_lane": 3
}

[sub_resource type="Resource" id="Rule_torchwood_combo_kill"]
script = ExtResource("4_rule")
rule_id = &"torchwood_combo_kill"
description = "Peashooter behind Torchwood should eventually kill the support-lane target."
event_name = &"entity.died"
required_core_values = {
"source_archetype_id": &"archetype_original_peashooter",
"target_archetype_id": &"archetype_basic_walker",
"target_lane": 4
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"original_defense_support_garden_validation"
display_name = "Original Defense Support Garden Validation"
description = "Showcase: wallnut, tallnut, pumpkin, spikeweed, spikerock and torchwood demonstrating defense, cover, ground damage, upgrade and projectile support behavior."
goals = PackedStringArray("Visual showcase of original defense and support plants in action.")
validation_time_limit = 45.0
initial_sun = 2000
lane_count = 5
card_defs = [ExtResource("5_peashooter_card"), ExtResource("6_pumpkin_card"), ExtResource("7_spikeweed_card"), ExtResource("8_spikerock_card")]
card_play_requests = [SubResource("Req_pumpkin_primary"), SubResource("Req_pumpkin"), SubResource("Req_spikeweed"), SubResource("Req_spikerock")]
validation_rules = [SubResource("Rule_wallnut_damaged"), SubResource("Rule_tallnut_damaged"), SubResource("Rule_pumpkin_accept"), SubResource("Rule_spikeweed_damage"), SubResource("Rule_spikerock_accept"), SubResource("Rule_torchwood_combo"), SubResource("Rule_spikeweed_kill"), SubResource("Rule_torchwood_combo_kill")]
spawns = [SubResource("Spawn_wallnut"), SubResource("Spawn_wallnut_biter"), SubResource("Spawn_tallnut"), SubResource("Spawn_tallnut_biter"), SubResource("Spawn_spike_target"), SubResource("Spawn_torchwood"), SubResource("Spawn_peashooter_torch"), SubResource("Spawn_torch_target")]
