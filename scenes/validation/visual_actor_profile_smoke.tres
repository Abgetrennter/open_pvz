[gd_resource type="Resource" script_class="BattleScenario" load_steps=9 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battle_spawn_entry.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="3_rule"]

[sub_resource type="Resource" id="Spawn_shooter"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_basic_shooter"
lane_id = 0
x_position = 160.0

[sub_resource type="Resource" id="Spawn_dummy"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_lane_dummy"
lane_id = 0
x_position = 650.0

[sub_resource type="Resource" id="Rule_entity_spawned"]
script = ExtResource("3_rule")
rule_id = &"entity_spawned"
description = "both entities should spawn without requiring visual profiles"
event_name = &"entity.spawned"
min_count = 2

[sub_resource type="Resource" id="Rule_no_profile_issues"]
script = ExtResource("3_rule")
rule_id = &"no_visual_profile_protocol_issues"
description = "no protocol issues from optional visual profile binding"
event_name = &"protocol.issue"
required_tags = PackedStringArray("protocol")
required_core_values = {
"scope": &"visual_profiles"
}
min_count = 0
max_count = 0

[sub_resource type="Resource" id="Rule_registry_probe"]
script = ExtResource("3_rule")
rule_id = &"visual_profile_registry_probe"
description = "visual profile registry should expose placeholder profile"
event_name = &"visual.validation_probe"
required_tags = PackedStringArray("visual", "validation")
required_core_values = {
"probe": &"registry",
"result": &"passed"
}
min_count = 1

[resource]
script = ExtResource("1_scenario")
scenario_id = &"visual_actor_profile_smoke"
display_name = "Visual Actor Profile Smoke"
description = "Verify that entities can exist with or without visual profiles while VisualProfileRegistry exposes placeholder core entries."
goals = PackedStringArray("Verify entities spawn without requiring visual profiles.", "Verify no protocol.issue with scope visual_profiles is emitted for optional visual binding.", "Verify VisualProfileRegistry has placeholder core entries.")
validation_time_limit = 3.0
validation_rules = [SubResource("Rule_entity_spawned"), SubResource("Rule_no_profile_issues"), SubResource("Rule_registry_probe")]
spawns = [SubResource("Spawn_shooter"), SubResource("Spawn_dummy")]
