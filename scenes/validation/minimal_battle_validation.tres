x_position = 650.0

[sub_resource type="Resource" id="BattleSpawnEntry_zombie_c"]
script = ExtResource("2_spawn")
entity_kind = &"zombie"
lane_id = 1
x_position = 520.0

[resource]
script = ExtResource("1_scenario")
scenario_id = &"minimal_battle_validation"
display_name = "Minimal Battle Validation"
description = "A deterministic validation battle for the engine backbone. It exercises tick triggers, effect execution, three projectile movement modes, damage callbacks, and death explosions on the same runtime."
goals = PackedStringArray("Observe a full event chain from game.tick to projectile.hit to entity.damaged.", "Verify linear, track, and parabola projectile movement across two lanes.", "Verify when_damaged and on_death triggers reuse the same EventBus, Context, and EffectExecutor.", "Press R to reset the battle and rerun the same validation sequence.")
spawns = [SubResource("BattleSpawnEntry_linear"), SubResource("BattleSpawnEntry_track"), SubResource("BattleSpawnEntry_parabola"), SubResource("BattleSpawnEntry_zombie_a"), SubResource("BattleSpawnEntry_zombie_b"), SubResource("BattleSpawnEntry_zombie_c")]
