[gd_resource type="Resource" script_class="BattleScenario" load_steps=10 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battle_spawn_entry.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/battle/card_play_request.gd" id="3_request"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="4_rule"]
[ext_resource type="Resource" path="res://data/combat/cards/original/card_original_scaredyshroom.tres" id="5_scaredy_card"]
[ext_resource type="Resource" path="res://data/combat/cards/original/card_original_coffeebean.tres" id="6_coffee_card"]

[sub_resource type="Resource" id="Spawn_near_target"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_basic_walker"
lane_id = 0
x_position = 220.0
spawn_overrides = {
"move_speed": 0.0
}

[sub_resource type="Resource" id="Req_scaredy"]
script = ExtResource("3_request")
at_time = 0.05
card_id = &"card_original_scaredyshroom"
lane_id = 0
slot_index = 0

[sub_resource type="Resource" id="Req_coffee"]
script = ExtResource("3_request")
at_time = 0.2
card_id = &"card_original_coffeebean"
lane_id = 0
slot_index = 0

[sub_resource type="Resource" id="Rule_cower_liveness"]
script = ExtResource("4_rule")
rule_id = &"scaredyshroom_cower_disables_triggers"
description = "Scaredy-shroom should disable firing triggers while an enemy is too close."
event_name = &"entity.liveness_changed"
required_core_values = {
"source_archetype_id": &"archetype_original_scaredyshroom",
"source_id": &"scaredy_cower",
"triggers": false
}

[sub_resource type="Resource" id="Rule_no_near_damage"]
script = ExtResource("4_rule")
rule_id = &"scaredyshroom_cower_blocks_damage"
description = "Cowering Scaredy-shroom should not damage the nearby target."
event_name = &"entity.damaged"
min_count = 0
max_count = 0
required_core_values = {
"source_archetype_id": &"archetype_original_scaredyshroom",
"target_archetype_id": &"archetype_basic_walker"
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"plant_original_scaredyshroom_cower_validation"
display_name = "Original Scaredy-shroom Cower Validation"
description = "Validates Scaredy-shroom near-enemy cower behavior disables firing."
goals = PackedStringArray("Verify close enemy proximity disables Scaredy-shroom triggers.", "Verify Scaredy-shroom does not damage a target while cowering.")
validation_time_limit = 2.0
initial_sun = 1000
lane_count = 1
card_defs = [ExtResource("5_scaredy_card"), ExtResource("6_coffee_card")]
card_play_requests = [SubResource("Req_scaredy"), SubResource("Req_coffee")]
validation_rules = [SubResource("Rule_cower_liveness"), SubResource("Rule_no_near_damage")]
spawns = [SubResource("Spawn_near_target")]
