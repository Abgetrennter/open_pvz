[gd_resource type="Resource" script_class="BattleScenario" load_steps=12 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battle_spawn_entry.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="3_rule"]
[ext_resource type="Script" path="res://scripts/battle/card_play_request.gd" id="4_request"]
[ext_resource type="Resource" path="res://data/combat/cards/original/card_original_jalapeno.tres" id="5_jalapeno_card"]

[sub_resource type="Resource" id="Spawn_jalapeno_target"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_brisk_runner"
lane_id = 0
x_position = 580.0
spawn_overrides = {"move_speed": 0.0}

[sub_resource type="Resource" id="Spawn_gloomshroom"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_original_gloomshroom"
lane_id = 1
x_position = 160.0

[sub_resource type="Resource" id="Spawn_gloom_target"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_basic_walker"
lane_id = 1
x_position = 300.0
spawn_overrides = {"move_speed": 0.0}

[sub_resource type="Resource" id="CardPlayRequest_jalapeno"]
script = ExtResource("4_request")
at_time = 0.1
card_id = &"card_original_jalapeno"
lane_id = 0
slot_index = 0

[sub_resource type="Resource" id="Rule_jalapeno_lane_explode"]
script = ExtResource("3_rule")
rule_id = &"jalapeno_lane"
description = "Jalapeno enemies_in_lane should damage a distant runner"
event_name = &"entity.damaged"
required_tags = PackedStringArray("explode")
required_core_values = {
"source_template_id": &"plant_jalapeno",
"target_template_id": &"zombie_brisk_runner",
"target_lane": 0
}

[sub_resource type="Resource" id="Rule_gloomshroom_damage"]
script = ExtResource("3_rule")
rule_id = &"gloomshroom_damage"
description = "Gloom-shroom should damage nearby targets with radius_around targeting"
event_name = &"entity.damaged"
required_core_values = {
"source_template_id": &"plant_gloomshroom"
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"plant_original_round1_validation"
display_name = "Original Plant Round 1 Validation"
description = "Validates Round 1 protocol extensions: Jalapeno enemies_in_lane explode, Gloom-shroom radius_around targeting."
goals = PackedStringArray("Verify Jalapeno enemies_in_lane damages distant runner.", "Verify Gloom-shroom radius_around damages nearby targets.")
validation_time_limit = 6.0
initial_sun = 500
lane_count = 2
card_defs = [ExtResource("5_jalapeno_card")]
card_play_requests = [SubResource("CardPlayRequest_jalapeno")]
validation_rules = [SubResource("Rule_jalapeno_lane_explode"), SubResource("Rule_gloomshroom_damage")]
spawns = [SubResource("Spawn_jalapeno_target"), SubResource("Spawn_gloomshroom"), SubResource("Spawn_gloom_target")]
