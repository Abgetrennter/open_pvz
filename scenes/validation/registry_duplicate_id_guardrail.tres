[gd_resource type="Resource" script_class="BattleScenario" load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="2_rule"]

[sub_resource type="Resource" id="Rule_duplicate_id_rejected"]
script = ExtResource("2_rule")
rule_id = &"duplicate_id_rejected"
description = "Extension contributor with duplicate id should be rejected and emit protocol.issue"
event_name = &"protocol.issue"
required_tags = PackedStringArray("protocol")
required_core_values = {
"scope": &"mechanic_compiler"
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"registry_duplicate_id_guardrail"
display_name = "Registry Duplicate ID Guardrail"
description = "Validates that duplicate contributor ids are rejected by RegistryBase and surfaced as protocol issues."
goals = PackedStringArray("Verify slot_guardrail_pack duplicate mechanic_compiler ids are rejected.", "Verify protocol.issue is emitted with correct scope.")
validation_time_limit = 0.5
validation_rules = [SubResource("Rule_duplicate_id_rejected")]
