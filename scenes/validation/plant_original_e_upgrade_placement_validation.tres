[resource]
script = ExtResource("1_scenario")
scenario_id = &"plant_original_e_upgrade_placement_validation"
display_name = "Original E Upgrade Placement Validation"
description = "Validates E batch upgrade placement dependencies use the upgrade role and require specific base archetypes."
goals = PackedStringArray("Verify available E upgrade plants can be placed over their specific base archetypes.", "Verify Cob Cannon rejects an incorrect base plant instead of satisfying upgrade placement by role alone.")
validation_time_limit = 2.0
initial_sun = 5000
lane_count = 8
board_slot_count = 1
board_slot_configs = [SubResource("Water_slot")]
card_defs = [ExtResource("5_repeater_card"), ExtResource("6_gatling_card"), ExtResource("7_sunflower_card"), ExtResource("8_twin_card"), ExtResource("9_fume_card"), ExtResource("10_gloom_card"), ExtResource("11_lily_card"), ExtResource("12_cattail_card"), ExtResource("13_melon_card"), ExtResource("14_winter_card"), ExtResource("15_magnet_card"), ExtResource("16_gold_card"), ExtResource("17_spikeweed_card"), ExtResource("18_spikerock_card"), ExtResource("19_peashooter_card"), ExtResource("20_cob_card")]
card_play_requests = [SubResource("Req_repeater"), SubResource("Req_gatling"), SubResource("Req_sunflower"), SubResource("Req_twin"), SubResource("Req_fume"), SubResource("Req_gloom"), SubResource("Req_lily"), SubResource("Req_cattail"), SubResource("Req_melon"), SubResource("Req_winter"), SubResource("Req_magnet"), SubResource("Req_gold"), SubResource("Req_spikeweed"), SubResource("Req_spikerock"), SubResource("Req_peashooter"), SubResource("Req_cob_wrong_base")]
validation_rules = [SubResource("Rule_gatling_accept"), SubResource("Rule_twin_accept"), SubResource("Rule_gloom_accept"), SubResource("Rule_cattail_accept"), SubResource("Rule_winter_accept"), SubResource("Rule_gold_accept"), SubResource("Rule_spikerock_accept"), SubResource("Rule_cob_wrong_base_reject")]
spawns = []
