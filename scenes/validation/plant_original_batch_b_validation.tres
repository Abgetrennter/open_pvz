[sub_resource type="Resource" id="Rule_jalapeno_damage"]
script = ExtResource("3_rule")
rule_id = &"jalapeno_lane_damage"
description = "Jalapeno should damage a distant target in its lane after card placement"
event_name = &"entity.damaged"
required_tags = PackedStringArray("explode")
required_core_values = {
"source_template_id": &"plant_jalapeno",
"target_template_id": &"zombie_brisk_runner",
"target_lane": 1
}

[sub_resource type="Resource" id="Rule_cherry_damage"]
script = ExtResource("3_rule")
rule_id = &"cherry_area_damage"
description = "Cherry Bomb should damage a nearby target after card placement"
event_name = &"entity.damaged"
required_tags = PackedStringArray("explode")
required_core_values = {
"source_template_id": &"plant_cherrybomb",
"target_template_id": &"zombie_basic_walker",
"target_lane": 0
}

[sub_resource type="Resource" id="Rule_tallnut_damaged"]
script = ExtResource("3_rule")
rule_id = &"tallnut_damaged"
description = "Tall-nut should receive damage from a zombie bite"
event_name = &"entity.damaged"
required_core_values = {
"target_template_id": &"plant_tallnut",
"target_lane": 2
}

[sub_resource type="Resource" id="Rule_pumpkin_spawned"]
script = ExtResource("3_rule")
rule_id = &"pumpkin_spawned"
description = "Pumpkin should spawn as a cover plant"
event_name = &"entity.spawned"
required_core_values = {
"archetype_id": &"archetype_original_pumpkin"
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"plant_original_batch_b_validation"
display_name = "Original Plant Batch B Validation"
description = "Validates Batch B original plants: Cherry Bomb on_place explode, Jalapeno lane explosion, Tall-nut tanking damage, Pumpkin cover placement."
goals = PackedStringArray("Verify Cherry Bomb explodes on placement and damages nearby enemies.", "Verify Jalapeno explodes and damages enemies in its lane.", "Verify Tall-nut can receive damage from zombie bites.", "Verify Pumpkin spawns as a cover plant.")
validation_time_limit = 6.0
initial_sun = 1000
lane_count = 4
card_defs = [ExtResource("5_cherry_card"), ExtResource("6_jalapeno_card"), ExtResource("7_pumpkin_card"), ExtResource("8_peashooter_card")]
card_play_requests = [SubResource("CardPlayRequest_pumpkin_primary"), SubResource("CardPlayRequest_cherry"), SubResource("CardPlayRequest_jalapeno"), SubResource("CardPlayRequest_pumpkin")]
validation_rules = [SubResource("Rule_cherry_damage"), SubResource("Rule_jalapeno_damage"), SubResource("Rule_tallnut_damaged"), SubResource("Rule_pumpkin_spawned")]
spawns = [SubResource("Spawn_cherry_target"), SubResource("Spawn_jalapeno_target"), SubResource("Spawn_tallnut"), SubResource("Spawn_tallnut_biter")]
