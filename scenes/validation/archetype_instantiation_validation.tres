[gd_resource type="Resource" script_class="BattleScenario" load_steps=6 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battle_spawn_entry.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="3_rule"]

[sub_resource type="Resource" id="Spawn_archetype_sunflower"]
script = ExtResource("2_spawn")
entity_kind = &"plant"
archetype_id = &"archetype_sunflower_skeleton"
lane_id = 0
x_position = 160.0
spawn_overrides = {
"interval": 0.5,
"start_delay": 0.3,
"value": 25
}

[sub_resource type="Resource" id="Rule_archetype_spawned"]
script = ExtResource("3_rule")
rule_id = &"archetype_spawned"
description = "archetype-instantiated sunflower should enter the runtime with archetype identity"
event_name = &"entity.spawned"
required_core_values = {
"target_archetype_id": &"archetype_sunflower_skeleton",
"target_kind": &"plant"
}

[sub_resource type="Resource" id="Rule_archetype_sun_spawn"]
script = ExtResource("3_rule")
rule_id = &"archetype_sun_spawn"
description = "compiled archetype RuntimeTriggerSpec should generate plant sun through the shared produce_sun effect"
event_name = &"sun.spawned"
required_core_values = {
"source_archetype_id": &"archetype_sunflower_skeleton",
"source_type": &"plant_generated",
"resource_id": &"sun"
}

[sub_resource type="Resource" id="Rule_archetype_resource_changed"]
script = ExtResource("3_rule")
rule_id = &"archetype_resource_changed"
description = "auto-collected sun from the archetype path should change the authoritative sun resource state"
event_name = &"resource.changed"
required_core_values = {
"reason": &"collect",
"resource_id": &"sun"
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"archetype_instantiation_validation"
display_name = "Archetype Instantiation Validation"
description = "Validates the first Mechanic-first skeleton path: BattleSpawnEntry resolves an archetype id, MechanicCompiler emits compiled RuntimeTriggerSpecs, and the spawned entity generates sun through the shared runtime."
goals = PackedStringArray("Verify BattleSpawnEntry can resolve a CombatArchetype through archetype_id.", "Verify the spawned entity carries archetype identity into events.", "Verify the compiled RuntimeTriggerSpec can drive produce_sun through the shared runtime.")
validation_time_limit = 2.0
initial_sun = 0
sun_auto_collect_delay = 0.2
validation_rules = [SubResource("Rule_archetype_spawned"), SubResource("Rule_archetype_sun_spawn"), SubResource("Rule_archetype_resource_changed")]
spawns = [SubResource("Spawn_archetype_sunflower")]