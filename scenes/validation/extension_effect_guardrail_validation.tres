[sub_resource type="Resource" id="Spawn_invalid_split_bad_param"]
script = ExtResource("2_spawn")
entity_template = SubResource("InvalidTemplate_split_bad_param")
lane_id = 0
x_position = 160.0

[sub_resource type="Resource" id="Spawn_invalid_slot_mismatch"]
script = ExtResource("2_spawn")
entity_template = SubResource("InvalidTemplate_slot_mismatch")
lane_id = 0
x_position = 240.0

[sub_resource type="Resource" id="Spawn_invalid_missing_strategy"]
script = ExtResource("2_spawn")
entity_template = SubResource("InvalidTemplate_missing_strategy")
lane_id = 0
x_position = 320.0

[sub_resource type="Resource" id="Rule_effect_def_issues"]
script = ExtResource("3_rule")
rule_id = &"extension_effect_def_issues"
description = "invalid extension effect definitions should be rejected during registry rebuild"
event_name = &"protocol.issue"
min_count = 3
required_core_values = {
"scope": &"effect_def"
}

[sub_resource type="Resource" id="Rule_effect_strategy_issues"]
script = ExtResource("3_rule")
rule_id = &"extension_effect_strategy_issues"
description = "extension effects without executable strategies should be rejected during registry rebuild"
event_name = &"protocol.issue"
min_count = 1
required_core_values = {
"scope": &"effect_strategy"
}

[sub_resource type="Resource" id="Rule_spawn_guardrail_issues"]
script = ExtResource("3_rule")
rule_id = &"extension_spawn_guardrail_issues"
description = "invalid extension effect bindings should be rejected before runtime execution"
event_name = &"protocol.issue"
min_count = 3
required_core_values = {
"scope": &"battle_spawn_entry"
}

[sub_resource type="Resource" id="Rule_no_projectile_spawn"]
script = ExtResource("3_rule")
rule_id = &"extension_guardrail_no_projectiles"
description = "guardrail samples should not spawn any projectiles"
event_name = &"projectile.spawned"
min_count = 0
max_count = 0

[sub_resource type="Resource" id="Rule_no_damage_events"]
script = ExtResource("3_rule")
rule_id = &"extension_guardrail_no_damage"
description = "guardrail samples should be blocked before any damage event is emitted"
event_name = &"entity.damaged"
min_count = 0
max_count = 0

[resource]
script = ExtResource("1_scenario")
scenario_id = &"extension_effect_guardrail_validation"
display_name = "Extension Effect Guardrail Validation"
description = "Validates extension effect guardrails across registry rebuild and spawn-entry binding checks, including duplicate ids, invalid effect defs, missing strategy execute entry points, slot tag mismatches, bad param types, and effects with no registered strategy."
goals = PackedStringArray("Verify invalid extension effect definitions emit protocol issues during registry rebuild.", "Verify an extension effect without execute() emits an effect_strategy protocol issue.", "Verify invalid extension on_hit bindings are rejected before any runtime projectile or damage execution begins.")
validation_time_limit = 0.9
validation_rules = [SubResource("Rule_effect_def_issues"), SubResource("Rule_effect_strategy_issues"), SubResource("Rule_spawn_guardrail_issues"), SubResource("Rule_no_projectile_spawn"), SubResource("Rule_no_damage_events")]
spawns = [SubResource("Spawn_invalid_split_bad_param"), SubResource("Spawn_invalid_slot_mismatch"), SubResource("Spawn_invalid_missing_strategy")]
