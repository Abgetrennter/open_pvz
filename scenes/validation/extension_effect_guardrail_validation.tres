[gd_resource type="Resource" script_class="BattleScenario" load_steps=7 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battle_spawn_entry.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="3_rule"]
[ext_resource type="Script" path="res://scripts/core/defs/entity_template.gd" id="4_template_script"]
[ext_resource type="Script" path="res://scripts/core/defs/trigger_binding.gd" id="5_binding_script"]
[ext_resource type="Resource" path="res://data/combat/height_bands/ground_unit.tres" id="6_ground_height"]
[ext_resource type="Resource" path="res://data/combat/projectile_templates/pea_linear.tres" id="7_projectile_template"]

[sub_resource type="Resource" id="InvalidBinding_split_bad_param"]
script = ExtResource("5_binding_script")
binding_id = &"invalid_extension_split_binding"
behavior_key = &"attack"
trigger_id = &"periodically"
event_name = &"game.tick"
condition_values = {
"detection_id": &"lane_forward",
"interval": 0.6,
"scan_range": 900.0
}
effect_id = &"spawn_projectile"
effect_params = {
"damage": 10,
"direction": Vector2(1, 0),
"speed": 220.0
}
on_hit_effect_id = &"split_projectiles"
on_hit_effect_params = {
"damage": 12,
"projectile_template": "not_a_resource"
}
projectile_template = ExtResource("7_projectile_template")

[sub_resource type="Resource" id="InvalidBinding_slot_mismatch"]
