"amount": 5
}

[sub_resource type="Resource" id="InvalidTemplate_split_bad_param"]
script = ExtResource("4_template_script")
template_id = &"invalid_extension_split_template"
entity_kind = &"plant"
display_name = "Invalid Extension Split Template"
hit_height_band = ExtResource("6_ground_height")
