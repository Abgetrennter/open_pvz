[gd_resource type="Resource" script_class="BattleScenario" load_steps=12 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battle_spawn_entry.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/battle/field_object_config.gd" id="3_field_config"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="4_rule"]

[sub_resource type="Resource" id="FieldObjectConfig_mower"]
script = ExtResource("3_field_config")
archetype_id = &"archetype_lawn_mower"
lane_id = 0
x_position = 80.0

[sub_resource type="Resource" id="BattleSpawnEntry_far_zombie"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_basic_walker"
lane_id = 0
x_position = 260.0
spawn_overrides = {
"move_speed_slots_per_sec": 0.0
}

[sub_resource type="Resource" id="BattleValidationRule_mower_spawned"]
script = ExtResource("4_rule")
rule_id = &"mower_spawned"
description = "lawn mower spawned"
event_name = &"field_object.spawned"

[sub_resource type="Resource" id="BattleValidationRule_no_mower_activated"]
script = ExtResource("4_rule")
rule_id = &"no_mower_activated"
description = "far same-lane zombie should not activate mower before contact range"
event_name = &"field_object.activated"
min_count = 0
max_count = 0

[sub_resource type="Resource" id="BattleValidationRule_no_zombie_killed"]
script = ExtResource("4_rule")
rule_id = &"no_zombie_killed"
description = "far same-lane zombie should not be killed by idle mower"
event_name = &"entity.died"
min_count = 0
max_count = 0

[sub_resource type="Resource" id="BattleValidationRule_no_mower_expired"]
script = ExtResource("4_rule")
rule_id = &"no_mower_expired"
description = "idle mower should not expire without activation"
event_name = &"field_object.expired"
min_count = 0
max_count = 0

[sub_resource type="Resource" id="BattleValidationRule_no_defeat"]
script = ExtResource("4_rule")
rule_id = &"no_defeat"
description = "no defeat triggered"
event_name = &"battle.defeat"
min_count = 0
max_count = 0

[resource]
script = ExtResource("1_scenario")
scenario_id = &"field_object_mower_contact_guard_validation"
display_name = "Field Object Mower Contact Guard Validation"
description = "Validates that a lawn mower does not activate merely because a targetable enemy exists farther ahead in the same lane."
goals = PackedStringArray("Observe the lawn mower spawn as a field object.", "Keep a targetable zombie farther ahead in the same lane.", "Confirm the mower does not activate, sweep, kill, expire, or trigger defeat.")
validation_time_limit = 1.0
defeat_line_x = 80.0
spawns = [SubResource("BattleSpawnEntry_far_zombie")]
field_object_configs = [SubResource("FieldObjectConfig_mower")]
validation_rules = [SubResource("BattleValidationRule_mower_spawned"), SubResource("BattleValidationRule_no_mower_activated"), SubResource("BattleValidationRule_no_zombie_killed"), SubResource("BattleValidationRule_no_mower_expired"), SubResource("BattleValidationRule_no_defeat")]
