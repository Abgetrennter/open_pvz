x_position = 160.0

[sub_resource type="Resource" id="Spawn_invalid_override_shape"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_basic_shooter"
lane_id = 1
x_position = 240.0
projectile_template_override = ExtResource("5_ground_height")

[sub_resource type="Resource" id="Spawn_mismatched_override"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_basic_shooter"
lane_id = 1
x_position = 320.0
spawn_overrides = {
"movement_mode": &"track",
"flight_profile": ExtResource("6_linear_profile")
}

[sub_resource type="Resource" id="Rule_template_protocol_issues"]
script = ExtResource("3_rule")
rule_id = &"template_protocol_issues"
description = "invalid template and override content should be rejected through protocol issues before runtime trigger binding"
event_name = &"protocol.issue"
min_count = 6
required_core_values = {
"scope": &"battle_spawn_entry"
}

[sub_resource type="Resource" id="Rule_no_projectiles"]
script = ExtResource("3_rule")
rule_id = &"template_no_projectiles"
description = "invalid template content should not be allowed to spawn projectiles"
event_name = &"projectile.spawned"
min_count = 0
max_count = 0

[sub_resource type="Resource" id="Rule_no_damage"]
script = ExtResource("3_rule")
rule_id = &"template_no_damage"
description = "invalid template content should be blocked before any damage event is emitted"
event_name = &"entity.damaged"
min_count = 0
max_count = 0

[resource]
script = ExtResource("1_scenario")
scenario_id = &"template_guardrail_validation"
display_name = "Template Guardrail Validation"
description = "Validates that invalid backend template resources, malformed trigger bindings, unresolved archetype ids, malformed override resources, and inconsistent projectile override combinations are rejected before runtime binding."
goals = PackedStringArray("Verify backend entity templates without template_id are rejected.", "Verify invalid trigger binding payloads, unsupported behavior_key values, event_name drift, and unsupported condition keys are rejected.", "Verify unresolved archetype_id and malformed projectile overrides are rejected.", "Verify inconsistent flight_profile and movement_mode combinations are blocked before runtime execution.")
validation_time_limit = 1.0
validation_rules = [SubResource("Rule_template_protocol_issues"), SubResource("Rule_no_projectiles"), SubResource("Rule_no_damage")]
spawns = [SubResource("Spawn_missing_template_id"), SubResource("Spawn_invalid_binding"), SubResource("Spawn_invalid_binding_contract"), SubResource("Spawn_invalid_binding_extra_condition"), SubResource("Spawn_unresolved_archetype_id"), SubResource("Spawn_invalid_override_shape"), SubResource("Spawn_mismatched_override")]

