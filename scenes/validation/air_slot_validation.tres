[gd_resource type="Resource" script_class="BattleScenario" load_steps=12 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/card_def.gd" id="2_card_def"]
[ext_resource type="Script" path="res://scripts/battle/card_play_request.gd" id="3_card_request"]
[ext_resource type="Script" path="res://scripts/battle/board_slot_config.gd" id="4_slot_config"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="5_rule"]

[sub_resource type="Resource" id="CardDef_ground_fail_air"]
script = ExtResource("2_card_def")
card_id = &"ground_fail_air_card"
display_name = "Ground Fail Air Card"
entity_template_id = &"plant_basic_shooter"
sun_cost = 25
cooldown_seconds = 0.0
placement_tags = PackedStringArray("air_only")

[sub_resource type="Resource" id="CardDef_air_perch"]
script = ExtResource("2_card_def")
card_id = &"air_perch_card"
display_name = "Air Perch Card"
entity_template_id = &"plant_air_perch"
sun_cost = 25
cooldown_seconds = 0.0

[sub_resource type="Resource" id="BattleCardPlayRequest_ground_fail_air"]
script = ExtResource("3_card_request")
at_time = 0.25
card_id = &"ground_fail_air_card"
lane_id = 0
slot_index = 1

[sub_resource type="Resource" id="BattleCardPlayRequest_air_perch"]
script = ExtResource("3_card_request")
at_time = 0.75
card_id = &"air_perch_card"
lane_id = 0
slot_index = 1

[sub_resource type="Resource" id="BoardSlotConfig_air_slot"]
script = ExtResource("4_slot_config")
lane_id = 0
slot_index = 1
slot_type = &"air_only"

[sub_resource type="Resource" id="BattleValidationRule_tick"]
script = ExtResource("5_rule")
rule_id = &"tick"
description = "at least one game tick event"
event_name = &"game.tick"

[sub_resource type="Resource" id="BattleValidationRule_ground_fail"]
script = ExtResource("5_rule")
rule_id = &"ground_fail"
description = "ground template is rejected on air-only slot"
event_name = &"placement.rejected"
required_core_values = {
"card_id": &"ground_fail_air_card",
"reason": &"template_tag_mismatch",
"slot_type": &"air_only"
}

[sub_resource type="Resource" id="BattleValidationRule_air_accept"]
script = ExtResource("5_rule")
rule_id = &"air_accept"
description = "air-only template is accepted on air-only slot"
event_name = &"placement.accepted"
required_core_values = {
"card_id": &"air_perch_card",
"placement_role": &"primary",
"slot_type": &"air_only"
}

[sub_resource type="Resource" id="BattleValidationRule_air_spawn"]
script = ExtResource("5_rule")
rule_id = &"air_spawn"
description = "air-only template spawns on air-only slot"
event_name = &"entity.spawned"
required_core_values = {
"card_id": &"air_perch_card",
"placement_role": &"primary",
"slot_type": &"air_only",
"spawn_reason": &"card_play"
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"air_slot_validation"
display_name = "Air Slot Validation"
description = "Validates that air-only slots reject unsupported templates and accept a template with matching static air-only constraints."
goals = PackedStringArray("Reject a normal primary plant on an air-only slot.", "Accept an air-only template on the same slot.", "Spawn the accepted air-only entity.")
validation_time_limit = 2.4
initial_sun = 100
board_slot_count = 2
board_slot_origin_x = 160.0
board_slot_spacing = 96.0
board_slot_configs = [SubResource("BoardSlotConfig_air_slot")]
card_defs = [SubResource("CardDef_ground_fail_air"), SubResource("CardDef_air_perch")]
card_play_requests = [SubResource("BattleCardPlayRequest_ground_fail_air"), SubResource("BattleCardPlayRequest_air_perch")]
validation_rules = [SubResource("BattleValidationRule_tick"), SubResource("BattleValidationRule_ground_fail"), SubResource("BattleValidationRule_air_accept"), SubResource("BattleValidationRule_air_spawn")]
spawns = []
