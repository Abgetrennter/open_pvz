[sub_resource type="Resource" id="Rule_puff_awake"]
script = ExtResource("5_rule")
rule_id = &"puff_awake"
description = "Coffee Bean should wake Puff-shroom."
event_name = &"entity.state_entered"
required_core_values = {
"source_archetype_id": &"archetype_original_puffshroom",
"state_id": &"awake"
}

[sub_resource type="Resource" id="Rule_puff_damage"]
script = ExtResource("5_rule")
rule_id = &"puff_damage"
description = "Awakened Puff-shroom should damage a close target."
event_name = &"entity.damaged"
required_core_values = {
"source_archetype_id": &"archetype_original_puffshroom",
"target_archetype_id": &"archetype_basic_walker",
"target_lane": 0
}

[sub_resource type="Resource" id="Rule_fume_awake"]
script = ExtResource("5_rule")
