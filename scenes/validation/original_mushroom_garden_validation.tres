[resource]
script = ExtResource("1_scenario")
scenario_id = &"original_mushroom_garden_validation"
display_name = "Original Mushroom Garden Validation"
description = "Showcase: puffshroom, fumeshroom, gloomshroom, seashroom and scaredyshroom demonstrating wake, pierce, area, water and long-range mushroom behavior."
goals = PackedStringArray("Visual showcase of original mushroom plants in action through wake, water and upgrade contexts.")
validation_time_limit = 45.0
initial_sun = 3000
lane_count = 5
board_slot_configs = [SubResource("Water_slot")]
card_defs = [ExtResource("7_puff_card"), ExtResource("8_fume_card"), SubResource("Card_fume_gloom_base"), ExtResource("9_gloom_card"), ExtResource("10_sea_card"), ExtResource("11_scaredy_card"), SubResource("Card_coffee_puff"), SubResource("Card_coffee_fume"), SubResource("Card_coffee_sea"), SubResource("Card_coffee_scaredy")]
card_play_requests = [SubResource("Req_puff"), SubResource("Req_coffee_puff"), SubResource("Req_fume"), SubResource("Req_coffee_fume"), SubResource("Req_fume_gloom_base"), SubResource("Req_gloom"), SubResource("Req_sea"), SubResource("Req_coffee_sea"), SubResource("Req_scaredy"), SubResource("Req_coffee_scaredy")]
validation_rules = [SubResource("Rule_puff_awake"), SubResource("Rule_puff_damage"), SubResource("Rule_fume_awake"), SubResource("Rule_fume_pierce"), SubResource("Rule_gloom_accept"), SubResource("Rule_gloom_damage"), SubResource("Rule_sea_awake"), SubResource("Rule_sea_damage"), SubResource("Rule_scaredy_awake"), SubResource("Rule_scaredy_damage"), SubResource("Rule_puff_kill"), SubResource("Rule_fume_kill"), SubResource("Rule_gloom_kill"), SubResource("Rule_sea_kill"), SubResource("Rule_scaredy_kill")]
spawns = [SubResource("Spawn_puff_target"), SubResource("Spawn_fume_target_a"), SubResource("Spawn_fume_target_b"), SubResource("Spawn_gloom_target"), SubResource("Spawn_sea_target"), SubResource("Spawn_scaredy_target")]
