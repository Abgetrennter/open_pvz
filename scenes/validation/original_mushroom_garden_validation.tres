[resource]
script = ExtResource("1_scenario")
scenario_id = &"original_mushroom_garden_validation"
display_name = "Original Mushroom Garden Validation"
description = "Showcase: puffshroom, fumeshroom, gloomshroom, seashroom and scaredyshroom demonstrating the mushroom family."
goals = PackedStringArray("Visual showcase of all original mushroom plants in action.")
validation_time_limit = 10.0
lane_count = 5
validation_rules = [SubResource("Rule_tick")]
spawns = [SubResource("Spawn_puffshroom"), SubResource("Spawn_walker_lane0"), SubResource("Spawn_fumeshroom"), SubResource("Spawn_walker_lane1"), SubResource("Spawn_runner_lane1"), SubResource("Spawn_gloomshroom"), SubResource("Spawn_walker_lane2"), SubResource("Spawn_seashroom"), SubResource("Spawn_walker_lane3"), SubResource("Spawn_scaredyshroom"), SubResource("Spawn_walker_lane4")]
