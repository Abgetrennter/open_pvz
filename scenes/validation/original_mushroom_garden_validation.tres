}

[sub_resource type="Resource" id="Rule_fume_pierce"]
script = ExtResource("5_rule")
rule_id = &"fume_pierce"
description = "Awakened Fume-shroom should pierce through two targets."
event_name = &"entity.damaged"
min_count = 2
required_core_values = {
"source_archetype_id": &"archetype_original_fumeshroom",
"target_lane": 1
}

[sub_resource type="Resource" id="Rule_gloom_accept"]
script = ExtResource("5_rule")
rule_id = &"gloom_fume_upgrade_accept"
description = "Gloom-shroom should replace Fume-shroom through entity.replaced."
event_name = &"entity.replaced"
required_core_values = {
"reason": &"upgrade_replacement",
"replaced_archetype_id": &"archetype_original_fumeshroom",
"replaced_role": &"primary",
"replacement_archetype_id": &"archetype_original_gloomshroom",
"replacement_role": &"upgrade"
}

