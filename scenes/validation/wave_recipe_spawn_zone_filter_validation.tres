[gd_resource type="Resource" script_class="BattleScenario" load_steps=17 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battlefield_preset.gd" id="2_preset"]
[ext_resource type="Script" path="res://scripts/battle/lane_config.gd" id="3_lane"]
[ext_resource type="Script" path="res://scripts/battle/spawn_zone_config.gd" id="4_zone"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="5_rule"]
[ext_resource type="Script" path="res://scripts/battle/wave_recipe_def.gd" id="6_recipe"]
[ext_resource type="Script" path="res://scripts/battle/wave_pool_def.gd" id="7_pool"]
[ext_resource type="Script" path="res://scripts/battle/wave_pool_entry_def.gd" id="8_pool_entry"]

[sub_resource type="Resource" id="LaneConfig_grass"]
script = ExtResource("3_lane")
lane_index = 0
lane_type = &"grass"

[sub_resource type="Resource" id="SpawnZone_ground"]
script = ExtResource("4_zone")
zone_id = &"ground_only_zone"
lane_id = 0
x = 700.0
zone_tags = PackedStringArray("spawn.medium.ground")

[sub_resource type="Resource" id="BattlefieldPreset_ground_only"]
script = ExtResource("2_preset")
preset_id = &"wave_recipe_ground_only"
display_name = "Wave Recipe Ground Only"
lane_count = 1
board_slot_count = 1
lane_configs = [SubResource("LaneConfig_grass")]
spawn_zones = [SubResource("SpawnZone_ground")]

[sub_resource type="Resource" id="WavePoolEntry_water"]
script = ExtResource("8_pool_entry")
archetype_id = &"archetype_original_ducky_tube"
power = 1
weight = 1
first_allowed_wave = 0
lane_id = 0
x_position = 520.0
required_spawn_tags = PackedStringArray("spawn.medium.water")
spawn_overrides = {
"move_speed_slots_per_sec": 0.0
}

[sub_resource type="Resource" id="WavePoolDef_water_only"]
script = ExtResource("7_pool")
pool_id = &"water_only_pool"
entries = [SubResource("WavePoolEntry_water")]

[sub_resource type="Resource" id="WaveRecipeDef_filter"]
script = ExtResource("6_recipe")
recipe_id = &"wave_spawn_filter_test"
total_waves = 1
waves_per_flag = 10
start_delay = 0.2
base_spacing = 1.0
base_budget = 1
budget_per_wave = 0
flag_budget_multiplier = 1.0
pool_def = SubResource("WavePoolDef_water_only")

[sub_resource type="Resource" id="Rule_wave_started"]
script = ExtResource("5_rule")
rule_id = &"filter_wave_started"
description = "recipe wave still starts after filtering incompatible entries"
event_name = &"wave.started"
required_core_values = {
"wave_id": &"wave_spawn_filter_test_0"
}

[sub_resource type="Resource" id="Rule_wave_completed"]
script = ExtResource("5_rule")
rule_id = &"filter_wave_completed"
description = "recipe wave completes without handing incompatible entries to the runtime resolver"
event_name = &"wave.completed"
required_core_values = {
"wave_id": &"wave_spawn_filter_test_0"
}

[sub_resource type="Resource" id="Rule_no_reject"]
script = ExtResource("5_rule")
rule_id = &"filter_no_reject"
description = "filtered recipe entries do not emit spawn.rejected"
event_name = &"spawn.rejected"
min_count = 0
max_count = 0

[sub_resource type="Resource" id="Rule_no_wave_spawn"]
script = ExtResource("5_rule")
rule_id = &"filter_no_wave_spawn"
description = "filtered water-only entry does not spawn in a ground-only preset"
event_name = &"entity.spawned"
min_count = 0
max_count = 0
required_core_values = {
"spawn_reason": &"wave_spawn"
}

[sub_resource type="Resource" id="Rule_battle_victory"]
script = ExtResource("5_rule")
rule_id = &"filter_battle_victory"
description = "filtered empty wave remains compatible with all-waves-cleared victory"
event_name = &"battle.victory"
required_core_values = {
"reason": &"all_waves_cleared"
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"wave_recipe_spawn_zone_filter_validation"
display_name = "Wave Recipe Spawn Zone Filter Validation"
description = "Validates recipe-level spawn tag filtering before entries reach the runtime spawn resolver."
goals = PackedStringArray("Compile a recipe against a ground-only spawn contract.", "Filter water-only pool entries at recipe compile time.", "Avoid spawn.rejected side effects from known-incompatible recipe entries.")
validation_time_limit = 1.2
battlefield_preset = SubResource("BattlefieldPreset_ground_only")
defeat_conditions = PackedStringArray()
wave_recipe = SubResource("WaveRecipeDef_filter")
validation_rules = [SubResource("Rule_wave_started"), SubResource("Rule_wave_completed"), SubResource("Rule_no_reject"), SubResource("Rule_no_wave_spawn"), SubResource("Rule_battle_victory")]
