[gd_resource type="Resource" script_class="BattleScenario" load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="2_rule"]

[sub_resource type="Resource" id="Rule_pass"]
script = ExtResource("2_rule")
rule_id = &"hit_policy_exposure_flying"
event_name = &"infrastructure.validation_probe"
required_core_values = {
"probe": &"hit_policy_exposure_flying",
"result": &"passed"
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"hit_policy_exposure_flying_validation"
display_name = "Hit Policy Exposure Flying Validation"
validation_time_limit = 1.2
validation_rules = [SubResource("Rule_pass")]
