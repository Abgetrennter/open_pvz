[gd_resource type="Resource" script_class="BattleScenario" load_steps=11 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battle_spawn_entry.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/battle/card_play_request.gd" id="3_request"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="4_rule"]
[ext_resource type="Resource" path="res://data/combat/cards/original/card_original_puffshroom.tres" id="5_puff_card"]
[ext_resource type="Resource" path="res://data/combat/cards/original/card_original_fumeshroom.tres" id="6_fume_card"]
[ext_resource type="Resource" path="res://data/combat/cards/original/card_original_coffeebean.tres" id="7_coffee_card"]

[sub_resource type="Resource" id="Spawn_puff_target"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_basic_walker"
lane_id = 0
x_position = 260.0
spawn_overrides = {
"move_speed": 0.0
}

[sub_resource type="Resource" id="Spawn_fume_target"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_brisk_runner"
lane_id = 1
x_position = 320.0
spawn_overrides = {
"move_speed": 0.0
}

[sub_resource type="Resource" id="CardPlayRequest_puff"]
script = ExtResource("3_request")
at_time = 0.05
card_id = &"card_original_puffshroom"
lane_id = 0
slot_index = 0

[sub_resource type="Resource" id="CardPlayRequest_fume"]
script = ExtResource("3_request")
at_time = 0.05
card_id = &"card_original_fumeshroom"
lane_id = 1
slot_index = 0

[sub_resource type="Resource" id="CardPlayRequest_coffee"]
script = ExtResource("3_request")
at_time = 0.2
card_id = &"card_original_coffeebean"
lane_id = 0
slot_index = 0

[sub_resource type="Resource" id="Rule_puff_awake"]
script = ExtResource("4_rule")
rule_id = &"puff_awake"
description = "Coffee Bean should wake the covered Puff-shroom primary"
event_name = &"entity.state_entered"
required_core_values = {
"source_template_id": &"plant_puffshroom",
"state_id": &"awake"
}

[sub_resource type="Resource" id="Rule_puff_damage"]
script = ExtResource("4_rule")
rule_id = &"puff_damage_after_wake"
description = "The awakened Puff-shroom should damage its lane target"
event_name = &"entity.damaged"
required_core_values = {
"source_template_id": &"plant_puffshroom",
"target_template_id": &"zombie_basic_walker",
"target_lane": 0
}

[sub_resource type="Resource" id="Rule_fume_not_awake"]
script = ExtResource("4_rule")
rule_id = &"fume_not_awake"
description = "Coffee Bean should not wake a different sleeping mushroom"
event_name = &"entity.state_entered"
min_count = 0
max_count = 0
required_core_values = {
"source_template_id": &"plant_fumeshroom",
"state_id": &"awake"
}

[sub_resource type="Resource" id="Rule_fume_no_damage"]
script = ExtResource("4_rule")
rule_id = &"fume_no_damage"
description = "The non-targeted Fume-shroom should remain asleep and not fire"
event_name = &"entity.damaged"
min_count = 0
max_count = 0
required_core_values = {
"source_template_id": &"plant_fumeshroom",
"target_lane": 1
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"plant_original_coffeebean_wake_validation"
display_name = "Original Coffee Bean Wake Validation"
description = "Validates Coffee Bean targeted wake semantics and guards against global mushroom wake-up."
goals = PackedStringArray("Verify Coffee Bean wakes the covered primary mushroom.", "Verify the awakened mushroom can act.", "Verify a different sleeping mushroom is not awakened or allowed to fire.")
validation_time_limit = 3.0
initial_sun = 1000
lane_count = 2
card_defs = [ExtResource("5_puff_card"), ExtResource("6_fume_card"), ExtResource("7_coffee_card")]
card_play_requests = [SubResource("CardPlayRequest_puff"), SubResource("CardPlayRequest_fume"), SubResource("CardPlayRequest_coffee")]
validation_rules = [SubResource("Rule_puff_awake"), SubResource("Rule_puff_damage"), SubResource("Rule_fume_not_awake"), SubResource("Rule_fume_no_damage")]
spawns = [SubResource("Spawn_puff_target"), SubResource("Spawn_fume_target")]
