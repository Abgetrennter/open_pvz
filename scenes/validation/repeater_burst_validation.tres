[gd_resource type="Resource" script_class="BattleScenario" load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battle_spawn_entry.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="3_rule"]

[sub_resource type="Resource" id="Spawn_repeater_lane0"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_repeater_burst"
lane_id = 0
x_position = 160.0

[sub_resource type="Resource" id="Spawn_basic_target"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_basic_walker"
lane_id = 0
x_position = 420.0

[sub_resource type="Resource" id="Spawn_repeater_lane1"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_repeater_burst"
lane_id = 1
x_position = 160.0

[sub_resource type="Resource" id="Spawn_runner_target"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_brisk_runner"
lane_id = 1
x_position = 500.0

[sub_resource type="Resource" id="Rule_repeater_spawn"]
script = ExtResource("3_rule")
rule_id = &"repeater_spawn"
description = "repeater burst should spawn multiple pea_burst projectiles across both lanes"
event_name = &"projectile.spawned"
min_count = 4
required_tags = PackedStringArray("projectile")
required_core_values = {
"source_archetype_id": &"archetype_repeater_burst",
"target_projectile_template_id": &"pea_burst"
}

[sub_resource type="Resource" id="Rule_repeater_hit_basic"]
script = ExtResource("3_rule")
rule_id = &"repeater_hit_basic"
description = "repeater burst should damage the basic walker target"
event_name = &"entity.damaged"
required_core_values = {
"source_archetype_id": &"archetype_repeater_burst",
"target_archetype_id": &"archetype_basic_walker",
"target_lane": 0,
"value": 20
}

[sub_resource type="Resource" id="Rule_repeater_hit_runner"]
script = ExtResource("3_rule")
rule_id = &"repeater_hit_runner"
description = "repeater burst should damage the brisk runner target"
event_name = &"entity.damaged"
required_core_values = {
"source_archetype_id": &"archetype_repeater_burst",
"target_archetype_id": &"archetype_brisk_runner",
"target_lane": 1,
"value": 20
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"repeater_burst_validation"
display_name = "Repeater Burst Validation"
description = "Validates that the repeater burst sample can instantiate from archetypes, spawn repeated pea_burst projectiles, and damage targets in two lanes."
goals = PackedStringArray("Verify plant_repeater_burst can spawn repeated projectiles through its RuntimeTriggerSpec.", "Verify the pea_burst projectile template enters runtime events.", "Verify both walker and runner zombie samples take repeater damage in their respective lanes.")
validation_time_limit = 3.0
validation_rules = [SubResource("Rule_repeater_spawn"), SubResource("Rule_repeater_hit_basic"), SubResource("Rule_repeater_hit_runner")]
spawns = [SubResource("Spawn_repeater_lane0"), SubResource("Spawn_basic_target"), SubResource("Spawn_repeater_lane1"), SubResource("Spawn_runner_target")]

