[gd_resource type="Resource" script_class="BattleScenario" load_steps=20 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battle_spawn_entry.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="3_rule"]
[ext_resource type="Script" path="res://scripts/battle/wave_recipe_def.gd" id="4_recipe"]
[ext_resource type="Script" path="res://scripts/battle/wave_pool_def.gd" id="5_pool"]
[ext_resource type="Script" path="res://scripts/battle/wave_pool_entry_def.gd" id="6_pool_entry"]

[sub_resource type="Resource" id="BattleSpawnEntry_recipe_plant"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_basic_shooter"
lane_id = 0
x_position = 160.0
spawn_overrides = {
"damage": 120,
"interval": 0.25,
"range_mode": &"full_lane",
"speed_slots_per_sec": 2.291667,
"start_delay": 0.0
}

[sub_resource type="Resource" id="WavePoolEntry_dummy"]
script = ExtResource("6_pool_entry")
archetype_id = &"archetype_lane_dummy"
power = 1
weight = 1
first_allowed_wave = 0
lane_id = 0
x_position = 520.0
spawn_overrides = {
"move_speed_slots_per_sec": 0.0
}

[sub_resource type="Resource" id="WavePoolEntry_flag"]
script = ExtResource("6_pool_entry")
archetype_id = &"archetype_original_flag_zombie"
power = 1
weight = 0
first_allowed_wave = 1
lane_id = 0
x_position = 520.0
spawn_overrides = {
"move_speed_slots_per_sec": 0.0
}

[sub_resource type="Resource" id="WavePoolDef_recipe"]
script = ExtResource("5_pool")
pool_id = &"recipe_compile_pool"
entries = [SubResource("WavePoolEntry_dummy")]

[sub_resource type="Resource" id="WaveRecipeDef_compile"]
script = ExtResource("4_recipe")
recipe_id = &"wave_recipe_test"
total_waves = 2
waves_per_flag = 2
start_delay = 0.2
base_spacing = 0.8
base_budget = 1
budget_per_wave = 0
flag_budget_multiplier = 1.0
pool_def = SubResource("WavePoolDef_recipe")
flag_entry = SubResource("WavePoolEntry_flag")

[sub_resource type="Resource" id="BattleValidationRule_phase_running"]
script = ExtResource("3_rule")
rule_id = &"phase_running"
description = "recipe wave plan enters running"
event_name = &"battle.phase_changed"
required_core_values = {
"after": &"running"
}

[sub_resource type="Resource" id="BattleValidationRule_wave0_started"]
script = ExtResource("3_rule")
rule_id = &"recipe_wave0_started"
description = "first compiled recipe wave starts"
event_name = &"wave.started"
required_core_values = {
"wave_id": &"wave_recipe_test_0"
}

[sub_resource type="Resource" id="BattleValidationRule_wave1_started"]
script = ExtResource("3_rule")
rule_id = &"recipe_wave1_started"
description = "second compiled recipe wave starts"
event_name = &"wave.started"
required_core_values = {
"wave_id": &"wave_recipe_test_1"
}

[sub_resource type="Resource" id="BattleValidationRule_dummy_spawned"]
script = ExtResource("3_rule")
rule_id = &"recipe_dummy_spawned"
description = "recipe pool spawns a regular zombie"
event_name = &"entity.spawned"
required_core_values = {
"archetype_id": &"archetype_lane_dummy",
"spawn_reason": &"wave_spawn",
"wave_id": &"wave_recipe_test_0"
}

[sub_resource type="Resource" id="BattleValidationRule_flag_spawned"]
script = ExtResource("3_rule")
rule_id = &"recipe_flag_spawned"
description = "recipe flag wave injects a flag zombie"
event_name = &"entity.spawned"
required_core_values = {
"archetype_id": &"archetype_original_flag_zombie",
"spawn_reason": &"wave_spawn",
"wave_id": &"wave_recipe_test_1"
}

[sub_resource type="Resource" id="BattleValidationRule_wave0_completed"]
script = ExtResource("3_rule")
rule_id = &"recipe_wave0_completed"
description = "first compiled recipe wave completes"
event_name = &"wave.completed"
required_core_values = {
"wave_id": &"wave_recipe_test_0"
}

[sub_resource type="Resource" id="BattleValidationRule_wave1_completed"]
script = ExtResource("3_rule")
rule_id = &"recipe_wave1_completed"
description = "second compiled recipe wave completes"
event_name = &"wave.completed"
required_core_values = {
"wave_id": &"wave_recipe_test_1"
}

[sub_resource type="Resource" id="BattleValidationRule_battle_victory"]
script = ExtResource("3_rule")
rule_id = &"recipe_battle_victory"
description = "compiled recipe waves can drive ordinary all-waves-cleared victory"
event_name = &"battle.victory"
required_core_values = {
"reason": &"all_waves_cleared"
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"wave_recipe_compile_validation"
display_name = "Wave Recipe Compile Validation"
description = "Validates that a WaveRecipeDef compiles into ordinary executable waves, including flag-wave insertion."
goals = PackedStringArray("Compile a two-wave recipe into WaveDef-compatible runtime data.", "Observe the second wave inject a Flag Zombie.", "Complete the compiled waves through the existing WaveRunner flow.")
validation_time_limit = 4.0
spawns = [SubResource("BattleSpawnEntry_recipe_plant")]
wave_recipe = SubResource("WaveRecipeDef_compile")
validation_rules = [SubResource("BattleValidationRule_phase_running"), SubResource("BattleValidationRule_wave0_started"), SubResource("BattleValidationRule_wave1_started"), SubResource("BattleValidationRule_dummy_spawned"), SubResource("BattleValidationRule_flag_spawned"), SubResource("BattleValidationRule_wave0_completed"), SubResource("BattleValidationRule_wave1_completed"), SubResource("BattleValidationRule_battle_victory")]
