[resource]
script = ExtResource("1_scenario")
scenario_id = &"original_special_garden_validation"
display_name = "Original Special Garden Validation"
description = "Showcase: chomper, squash, tanglekelp, cobcannon, blover and hypnoshroom demonstrating special abilities and manual-upgrade readiness through their required contexts."
goals = PackedStringArray("Visual showcase of original special plants with placement, water, upgrade, air-target and wake prerequisites.", "Verify Cob Cannon reaches its real upgrade placement context; manual firing is not auto-triggered by this scene.")
validation_time_limit = 20.0
initial_sun = 3000
lane_count = 6
board_slot_configs = [SubResource("Water_slot")]
card_defs = [ExtResource("6_squash_card"), ExtResource("7_tangle_card"), ExtResource("8_kernel_card"), ExtResource("9_cob_card"), ExtResource("10_blover_card"), ExtResource("11_hypno_card"), ExtResource("12_coffee_card"), ExtResource("13_chomper_card"), SubResource("Card_kernel_neighbor")]
card_play_requests = [SubResource("Req_chomper"), SubResource("Req_squash"), SubResource("Req_tangle"), SubResource("Req_kernel"), SubResource("Req_kernel_neighbor"), SubResource("Req_cob"), SubResource("Req_blover"), SubResource("Req_hypno"), SubResource("Req_coffee")]
validation_rules = [SubResource("Rule_chomper_damage"), SubResource("Rule_squash_damage"), SubResource("Rule_tangle_accept"), SubResource("Rule_tangle_damage"), SubResource("Rule_cob_accept"), SubResource("Rule_blover_damage"), SubResource("Rule_hypno_awake"), SubResource("Rule_hypno_team_switch"), SubResource("Rule_chomper_kill"), SubResource("Rule_squash_kill"), SubResource("Rule_tangle_kill"), SubResource("Rule_blover_kill")]
spawns = [SubResource("Spawn_chomper_target"), SubResource("Spawn_squash_target"), SubResource("Spawn_tangle_target"), SubResource("Spawn_cob_target"), SubResource("Spawn_air_target"), SubResource("Spawn_hypno_target")]
