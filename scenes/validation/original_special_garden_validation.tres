[resource]
script = ExtResource("1_scenario")
scenario_id = &"original_special_garden_validation"
display_name = "Original Special Garden Validation"
description = "Showcase: chomper, squash, tanglekelp, cobcannon, blover and hypnoshroom demonstrating unique special abilities."
goals = PackedStringArray("Visual showcase of all original special plants in action.")
validation_time_limit = 8.0
lane_count = 5
validation_rules = [SubResource("Rule_tick")]
spawns = [SubResource("Spawn_chomper"), SubResource("Spawn_walker_lane0"), SubResource("Spawn_squash"), SubResource("Spawn_walker_lane1"), SubResource("Spawn_tanglekelp"), SubResource("Spawn_walker_lane2"), SubResource("Spawn_cobcannon"), SubResource("Spawn_walker_lane3"), SubResource("Spawn_blover"), SubResource("Spawn_hypnoshroom"), SubResource("Spawn_walker_lane4")]
