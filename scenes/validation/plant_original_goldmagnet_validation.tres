[gd_resource type="Resource" script_class="BattleScenario" load_steps=10 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/card_play_request.gd" id="2_request"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="3_rule"]
[ext_resource type="Resource" path="res://data/combat/cards/original/card_original_magnetshroom.tres" id="4_magnet_card"]
[ext_resource type="Resource" path="res://data/combat/cards/original/card_original_goldmagnet.tres" id="5_gold_card"]

[sub_resource type="Resource" id="Req_magnet"]
script = ExtResource("2_request")
at_time = 0.05
card_id = &"card_original_magnetshroom"
lane_id = 0
slot_index = 0

[sub_resource type="Resource" id="Req_gold"]
script = ExtResource("2_request")
at_time = 0.3
card_id = &"card_original_goldmagnet"
lane_id = 0
slot_index = 0

[sub_resource type="Resource" id="Rule_gold_accept"]
script = ExtResource("3_rule")
rule_id = &"gold_accept"
description = "Gold Magnet should be accepted as an upgrade over Magnet-shroom."
event_name = &"placement.accepted"
required_core_values = {
"card_id": &"card_original_goldmagnet",
"placement_role": &"upgrade",
"upgrade_archetype_id": &"archetype_original_goldmagnet"
}

[sub_resource type="Resource" id="Rule_gold_replace"]
script = ExtResource("3_rule")
rule_id = &"gold_replace"
description = "Gold Magnet should replace the Magnet-shroom base."
event_name = &"entity.replaced"
required_core_values = {
"reason": &"upgrade_replacement",
"replaced_archetype_id": &"archetype_original_magnetshroom",
"replacement_archetype_id": &"archetype_original_goldmagnet"
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"plant_original_goldmagnet_validation"
display_name = "Original Gold Magnet Validation"
description = "Validates Gold Magnet's currently supported minimal semantics: upgrade placement over Magnet-shroom."
goals = PackedStringArray("Verify Gold Magnet upgrades from Magnet-shroom.", "Keep full collectible attraction explicitly out of scope until the coin/silver economy is expanded.")
validation_time_limit = 2.0
initial_sun = 1000
lane_count = 1
board_slot_count = 1
card_defs = [ExtResource("4_magnet_card"), ExtResource("5_gold_card")]
card_play_requests = [SubResource("Req_magnet"), SubResource("Req_gold")]
validation_rules = [SubResource("Rule_gold_accept"), SubResource("Rule_gold_replace")]
