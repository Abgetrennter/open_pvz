[gd_resource type="Resource" script_class="BattleScenario" load_steps=20 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/card_play_request.gd" id="2_request"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="3_rule"]
[ext_resource type="Script" path="res://scripts/battle/card_def.gd" id="4_card_def"]
[ext_resource type="Resource" path="res://data/combat/cards/original/card_original_sunflower.tres" id="5_sunflower_card"]
[ext_resource type="Resource" path="res://data/combat/cards/original/card_original_twinsunflower.tres" id="6_twin_card"]
[ext_resource type="Resource" path="res://data/combat/cards/original/card_original_sunshroom.tres" id="7_sunshroom_card"]
[ext_resource type="Resource" path="res://data/combat/cards/original/card_original_coffeebean.tres" id="8_coffee_card"]
[ext_resource type="Resource" path="res://data/combat/cards/original/card_original_marigold.tres" id="9_marigold_card"]

[sub_resource type="Resource" id="Card_sunflower_upgrade_base"]
script = ExtResource("4_card_def")
card_id = &"showcase_sunflower_upgrade_base"
display_name = "Sunflower Base"
archetype_id = &"archetype_original_sunflower"
sun_cost = 50
cooldown_seconds = 0.0
placement_tags = PackedStringArray("supports_primary")

[sub_resource type="Resource" id="Req_sunflower"]
script = ExtResource("2_request")
at_time = 0.05
card_id = &"card_original_sunflower"
lane_id = 0
slot_index = 0

[sub_resource type="Resource" id="Req_sunflower_base"]
script = ExtResource("2_request")
at_time = 0.05
card_id = &"showcase_sunflower_upgrade_base"
lane_id = 1
slot_index = 0

[sub_resource type="Resource" id="Req_twin"]
script = ExtResource("2_request")
at_time = 0.3
card_id = &"card_original_twinsunflower"
lane_id = 1
slot_index = 0

[sub_resource type="Resource" id="Req_sunshroom"]
script = ExtResource("2_request")
at_time = 0.05
card_id = &"card_original_sunshroom"
lane_id = 2
slot_index = 0

[sub_resource type="Resource" id="Req_coffee"]
script = ExtResource("2_request")
at_time = 0.25
card_id = &"card_original_coffeebean"
lane_id = 2
slot_index = 0

[sub_resource type="Resource" id="Req_marigold"]
script = ExtResource("2_request")
at_time = 0.05
card_id = &"card_original_marigold"
lane_id = 3
slot_index = 0

[sub_resource type="Resource" id="Rule_sunflower_sun"]
script = ExtResource("3_rule")
rule_id = &"sunflower_sun"
description = "Sunflower should produce plant-generated sun."
event_name = &"sun.spawned"
required_core_values = {
"source_archetype_id": &"archetype_original_sunflower",
"source_type": &"plant_generated",
"value": 25
}

[sub_resource type="Resource" id="Rule_twin_accept"]
script = ExtResource("3_rule")
rule_id = &"twin_upgrade_accept"
description = "Twin Sunflower should be accepted as an upgrade over Sunflower."
event_name = &"placement.accepted"
required_core_values = {
"card_id": &"card_original_twinsunflower",
"placement_role": &"upgrade",
"primary_archetype_id": &"archetype_original_sunflower"
}

[sub_resource type="Resource" id="Rule_twin_sun"]
script = ExtResource("3_rule")
rule_id = &"twin_sun"
description = "Twin Sunflower should produce a larger plant-generated sun collectible."
event_name = &"sun.spawned"
required_core_values = {
"source_archetype_id": &"archetype_original_twinsunflower",
"source_type": &"plant_generated",
"value": 50
}

[sub_resource type="Resource" id="Rule_sunshroom_awake"]
script = ExtResource("3_rule")
rule_id = &"sunshroom_awake"
description = "Coffee Bean should wake Sun-shroom."
event_name = &"entity.state_entered"
required_core_values = {
"source_archetype_id": &"archetype_original_sunshroom",
"state_id": &"awake"
}

[sub_resource type="Resource" id="Rule_sunshroom_sun"]
script = ExtResource("3_rule")
rule_id = &"sunshroom_sun"
description = "Awakened Sun-shroom should produce plant-generated sun."
event_name = &"sun.spawned"
required_core_values = {
"source_archetype_id": &"archetype_original_sunshroom",
"source_type": &"plant_generated",
"value": 15
}

[sub_resource type="Resource" id="Rule_marigold_coin"]
script = ExtResource("3_rule")
rule_id = &"marigold_coin"
description = "Marigold should produce a coin-generated collectible."
event_name = &"sun.spawned"
required_core_values = {
"source_archetype_id": &"archetype_original_marigold",
"source_type": &"coin_generated",
"value": 50
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"original_production_garden_validation"
display_name = "Original Production Garden Validation"
description = "Showcase: sunflower, twinsunflower, sunshroom and marigold producing sun and coin collectibles through placement and wake contexts."
goals = PackedStringArray("Visual showcase of original production plants in action.")
validation_time_limit = 12.0
initial_sun = 2000
sun_auto_collect_delay = 0.5
lane_count = 4
card_defs = [ExtResource("5_sunflower_card"), SubResource("Card_sunflower_upgrade_base"), ExtResource("6_twin_card"), ExtResource("7_sunshroom_card"), ExtResource("8_coffee_card"), ExtResource("9_marigold_card")]
card_play_requests = [SubResource("Req_sunflower"), SubResource("Req_sunflower_base"), SubResource("Req_twin"), SubResource("Req_sunshroom"), SubResource("Req_coffee"), SubResource("Req_marigold")]
validation_rules = [SubResource("Rule_sunflower_sun"), SubResource("Rule_twin_accept"), SubResource("Rule_twin_sun"), SubResource("Rule_sunshroom_awake"), SubResource("Rule_sunshroom_sun"), SubResource("Rule_marigold_coin")]
spawns = []
