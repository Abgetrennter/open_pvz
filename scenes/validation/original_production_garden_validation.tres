[gd_resource type="Resource" script_class="BattleScenario" load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battle_spawn_entry.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="3_rule"]

[sub_resource type="Resource" id="Spawn_sunflower"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_original_sunflower"
lane_id = 0
x_position = 160.0

[sub_resource type="Resource" id="Spawn_twinsunflower"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_original_twinsunflower"
lane_id = 1
x_position = 160.0

[sub_resource type="Resource" id="Spawn_sunshroom"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_original_sunshroom"
lane_id = 2
x_position = 160.0

[sub_resource type="Resource" id="Spawn_coffeebean"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_original_coffeebean"
lane_id = 2
x_position = 120.0

[sub_resource type="Resource" id="Spawn_marigold"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_original_marigold"
lane_id = 3
x_position = 160.0

[sub_resource type="Resource" id="Rule_tick"]
script = ExtResource("3_rule")
rule_id = &"tick"
description = "at least one game tick"
event_name = &"game.tick"

[resource]
script = ExtResource("1_scenario")
scenario_id = &"original_production_garden_validation"
display_name = "Original Production Garden Validation"
description = "Showcase: sunflower, twinsunflower, sunshroom and marigold producing sun and coins in parallel."
goals = PackedStringArray("Visual showcase of all original production plants in action.")
validation_time_limit = 12.0
initial_sun = 0
sun_auto_collect_delay = 0.5
lane_count = 4
validation_rules = [SubResource("Rule_tick")]
spawns = [SubResource("Spawn_sunflower"), SubResource("Spawn_twinsunflower"), SubResource("Spawn_sunshroom"), SubResource("Spawn_coffeebean"), SubResource("Spawn_marigold")]
