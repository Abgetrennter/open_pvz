[gd_resource type="Resource" script_class="BattleScenario" load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battle_spawn_entry.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="3_rule"]

[sub_resource type="Resource" id="Spawn_cabbage_lobber"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_cabbage_lobber"
lane_id = 0
x_position = 160.0
spawn_overrides = {
"speed": 80.0,
"travel_duration": 2.2
}

[sub_resource type="Resource" id="Spawn_bucket_target"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_bucket_tank"
lane_id = 0
x_position = 480.0

[sub_resource type="Resource" id="Spawn_melon_lobber"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_melon_lobber"
lane_id = 1
x_position = 160.0
spawn_overrides = {
"speed": 80.0,
"travel_duration": 2.4
}

[sub_resource type="Resource" id="Spawn_cluster_target_a"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_basic_walker"
lane_id = 1
x_position = 520.0
spawn_overrides = {
"move_speed": 0.0
}

[sub_resource type="Resource" id="Spawn_cluster_target_b"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_brisk_runner"
lane_id = 1
x_position = 580.0
spawn_overrides = {
"move_speed": 0.0
}

[sub_resource type="Resource" id="Rule_cabbage_spawn"]
script = ExtResource("3_rule")
rule_id = &"cabbage_spawn"
description = "cabbage lobber should spawn the cabbage_arc projectile profile"
event_name = &"projectile.spawned"
required_tags = PackedStringArray("projectile")
required_core_values = {
"profile_id": &"parabola_cabbage_arc",
"source_archetype_id": &"archetype_cabbage_lobber",
"target_projectile_template_id": &"cabbage_arc"
}

[sub_resource type="Resource" id="Rule_cabbage_hit_bucket"]
script = ExtResource("3_rule")
rule_id = &"cabbage_hit_bucket"
description = "cabbage lobber should hit the bucket tank target"
event_name = &"projectile.hit"
required_tags = PackedStringArray("projectile")
required_core_values = {
"source_archetype_id": &"archetype_cabbage_lobber",
"target_archetype_id": &"archetype_bucket_tank",
"target_lane": 0
}

[sub_resource type="Resource" id="Rule_melon_spawn"]
script = ExtResource("3_rule")
rule_id = &"melon_spawn"
description = "melon lobber should spawn the melon_blast projectile profile"
event_name = &"projectile.spawned"
required_tags = PackedStringArray("projectile")
required_core_values = {
"profile_id": &"parabola_terminal_blast",
"source_archetype_id": &"archetype_melon_lobber",
"target_projectile_template_id": &"melon_blast"
}

[sub_resource type="Resource" id="Rule_melon_explode"]
script = ExtResource("3_rule")
rule_id = &"melon_explode"
description = "melon lobber terminal blast should damage both clustered targets"
event_name = &"entity.damaged"
min_count = 2
required_tags = PackedStringArray("explode", "projectile.hit")
required_core_values = {
"source_archetype_id": &"archetype_melon_lobber",
"target_lane": 1
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"lobber_catalog_validation"
display_name = "Lobber Catalog Validation"
description = "Validates that the cabbage and melon lobber samples can spawn their dedicated projectile templates and resolve direct-hit and terminal-blast behaviors through the projectile content chain."
goals = PackedStringArray("Verify plant_cabbage_lobber can spawn cabbage_arc projectiles.", "Verify plant_melon_lobber can spawn melon_blast projectiles.", "Verify melon_blast can hand off to explode-tagged clustered damage.")
validation_time_limit = 4.5
validation_rules = [SubResource("Rule_cabbage_spawn"), SubResource("Rule_cabbage_hit_bucket"), SubResource("Rule_melon_spawn"), SubResource("Rule_melon_explode")]
spawns = [SubResource("Spawn_cabbage_lobber"), SubResource("Spawn_bucket_target"), SubResource("Spawn_melon_lobber"), SubResource("Spawn_cluster_target_a"), SubResource("Spawn_cluster_target_b")]

