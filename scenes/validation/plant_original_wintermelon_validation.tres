[gd_resource type="Resource" script_class="BattleScenario" load_steps=12 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/card_play_request.gd" id="2_request"]
[ext_resource type="Script" path="res://scripts/battle/battle_spawn_entry.gd" id="3_spawn"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="4_rule"]
[ext_resource type="Resource" path="res://data/combat/cards/original/card_original_melonpult.tres" id="5_melon_card"]
[ext_resource type="Resource" path="res://data/combat/cards/original/card_original_wintermelon.tres" id="6_winter_card"]

[sub_resource type="Resource" id="Req_melon"]
script = ExtResource("2_request")
at_time = 0.05
card_id = &"card_original_melonpult"
lane_id = 0
slot_index = 0

[sub_resource type="Resource" id="Req_winter"]
script = ExtResource("2_request")
at_time = 0.3
card_id = &"card_original_wintermelon"
lane_id = 0
slot_index = 0

[sub_resource type="Resource" id="Spawn_target_a"]
script = ExtResource("3_spawn")
archetype_id = &"archetype_basic_walker"
lane_id = 0
x_position = 500.0
spawn_overrides = {"move_speed_slots_per_sec": 0.0}

[sub_resource type="Resource" id="Spawn_target_b"]
script = ExtResource("3_spawn")
archetype_id = &"archetype_brisk_runner"
lane_id = 0
x_position = 560.0
spawn_overrides = {"move_speed_slots_per_sec": 0.0}

[sub_resource type="Resource" id="Rule_winter_accept"]
script = ExtResource("4_rule")
rule_id = &"winter_accept"
description = "Winter Melon should be accepted as an upgrade over Melon-pult."
event_name = &"placement.accepted"
required_core_values = {
"card_id": &"card_original_wintermelon",
"placement_role": &"upgrade",
"upgrade_archetype_id": &"archetype_original_wintermelon"
}

[sub_resource type="Resource" id="Rule_winter_replace"]
script = ExtResource("4_rule")
rule_id = &"winter_replace"
description = "Winter Melon should replace the Melon-pult base."
event_name = &"entity.replaced"
required_core_values = {
"reason": &"upgrade_replacement",
"replaced_archetype_id": &"archetype_original_melonpult",
"replacement_archetype_id": &"archetype_original_wintermelon"
}

[sub_resource type="Resource" id="Rule_winter_splash"]
script = ExtResource("4_rule")
rule_id = &"winter_splash"
description = "Winter Melon should damage clustered enemies through its terminal blast."
event_name = &"entity.damaged"
min_count = 2
required_tags = PackedStringArray("explode", "projectile.hit")
required_core_values = {
"source_archetype_id": &"archetype_original_wintermelon",
"target_lane": 0
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"plant_original_wintermelon_validation"
display_name = "Original Winter Melon Validation"
description = "Validates Winter Melon upgrade placement and current terminal blast damage."
goals = PackedStringArray("Verify Winter Melon upgrades from Melon-pult.", "Verify Winter Melon damages clustered enemies through its terminal blast path.")
validation_time_limit = 6.0
initial_sun = 1000
lane_count = 1
board_slot_count = 1
card_defs = [ExtResource("5_melon_card"), ExtResource("6_winter_card")]
card_play_requests = [SubResource("Req_melon"), SubResource("Req_winter")]
validation_rules = [SubResource("Rule_winter_accept"), SubResource("Rule_winter_replace"), SubResource("Rule_winter_splash")]
spawns = [SubResource("Spawn_target_a"), SubResource("Spawn_target_b")]
