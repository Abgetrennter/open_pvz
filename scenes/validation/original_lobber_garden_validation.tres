description = "at least one game tick"
event_name = &"game.tick"

[resource]
script = ExtResource("1_scenario")
scenario_id = &"original_lobber_garden_validation"
display_name = "Original Lobber Garden Validation"
description = "Showcase: cabbagepult, kernelpult, melonpult and starfruit demonstrating lob and multi-direction projectile attacks."
goals = PackedStringArray("Visual showcase of all original lobber plants in action.")
validation_time_limit = 10.0
lane_count = 4
validation_rules = [SubResource("Rule_tick")]
spawns = [SubResource("Spawn_cabbagepult"), SubResource("Spawn_walker_lane0"), SubResource("Spawn_kernelpult"), SubResource("Spawn_walker_lane1"), SubResource("Spawn_melonpult"), SubResource("Spawn_walker_lane2"), SubResource("Spawn_runner_lane2"), SubResource("Spawn_starfruit"), SubResource("Spawn_walker_lane3")]
