[gd_resource type="Resource" script_class="BattleScenario" load_steps=10 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battle_spawn_entry.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="3_rule"]

[sub_resource type="Resource" id="Spawn_frost_pea"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_frost_pea"
entity_template_id = &"plant_frost_pea"
lane_id = 0
x_position = 160.0

[sub_resource type="Resource" id="Spawn_spore_summoner"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_spore_summoner"
entity_template_id = &"plant_spore_summoner"
lane_id = 0
x_position = 250.0

[sub_resource type="Resource" id="Spawn_target_dummy"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_basic_walker"
entity_template_id = &"zombie_basic_walker"
lane_id = 0
x_position = 430.0

[sub_resource type="Resource" id="Rule_slow_applied"]
script = ExtResource("3_rule")
rule_id = &"phase6_plant_slow"
description = "frost pea should apply slowed to a frontline zombie through the shared status effect chain"
event_name = &"entity.status_applied"
required_core_values = {
"source_template_id": &"plant_frost_pea",
"status_id": &"slowed",
"target_template_id": &"zombie_basic_walker"
}

[sub_resource type="Resource" id="Rule_spore_summon"]
script = ExtResource("3_rule")
rule_id = &"phase6_plant_summon"
description = "spore summoner should periodically spawn a sporeling through the shared summon effect chain"
event_name = &"entity.spawned"
required_core_values = {
"archetype_id": &"archetype_sporeling",
"source_template_id": &"plant_spore_summoner",
"spawn_reason": &"summon"
}

[sub_resource type="Resource" id="Rule_sporeling_attack"]
script = ExtResource("3_rule")
rule_id = &"phase6_sporeling_attack"
description = "summoned sporelings should enter the shared attack runtime and spawn projectiles"
event_name = &"projectile.spawned"
required_tags = PackedStringArray("projectile")
required_core_values = {
"source_template_id": &"plant_sporeling"
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"plant_roster_phase6_validation"
display_name = "Plant Roster Phase 6 Validation"
description = "Validates the first formal Phase 6 plant roster additions for control and summon roles through shared built-in runtime effects."
goals = PackedStringArray("Verify a formal control plant applies slowed through the built-in status effect.", "Verify a formal summon plant spawns combat-ready sporelings through the built-in summon effect.", "Verify summoned units reuse the same projectile runtime as normal template content.")
validation_time_limit = 6.5
validation_rules = [SubResource("Rule_slow_applied"), SubResource("Rule_spore_summon"), SubResource("Rule_sporeling_attack")]
spawns = [SubResource("Spawn_frost_pea"), SubResource("Spawn_spore_summoner"), SubResource("Spawn_target_dummy")]


