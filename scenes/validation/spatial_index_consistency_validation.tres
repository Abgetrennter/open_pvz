[gd_resource type="Resource" script_class="BattleScenario" load_steps=12 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battle_spawn_entry.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="3_rule"]

[sub_resource type="Resource" id="Spawn_source_wall"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_wall_barrier"
lane_id = 1
x_position = 160.0

[sub_resource type="Resource" id="Spawn_lane_basic"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_basic_walker"
lane_id = 1
x_position = 240.0
spawn_overrides = {
"move_speed": 0.0
}

[sub_resource type="Resource" id="Spawn_lane_fast"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_brisk_runner"
lane_id = 1
x_position = 320.0
spawn_overrides = {
"move_speed": 0.0
}

[sub_resource type="Resource" id="Spawn_off_lane"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_basic_walker"
lane_id = 2
x_position = 280.0
spawn_overrides = {
"move_speed": 0.0
}

[sub_resource type="Resource" id="Spawn_air_scout"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_air_scout"
lane_id = 1
x_position = 280.0
spawn_overrides = {
"move_speed": 0.0
}

[sub_resource type="Resource" id="Rule_lane_team_x"]
script = ExtResource("3_rule")
rule_id = &"spatial_lane_team_x"
description = "SpatialIndex lane/team/x query should match a full scan baseline."
event_name = &"infrastructure.validation_probe"
required_core_values = {
"probe": &"spatial_lane_team_x",
"result": &"passed"
}

[sub_resource type="Resource" id="Rule_tag_kind"]
script = ExtResource("3_rule")
rule_id = &"spatial_tag_kind"
description = "SpatialIndex tag/kind query should match a full scan baseline."
event_name = &"infrastructure.validation_probe"
required_core_values = {
"probe": &"spatial_tag_kind",
"result": &"passed"
}

[sub_resource type="Resource" id="Rule_height_range"]
script = ExtResource("3_rule")
rule_id = &"spatial_height_range"
description = "SpatialIndex height_range query should match a full scan baseline."
event_name = &"infrastructure.validation_probe"
required_core_values = {
"probe": &"spatial_height_range",
"result": &"passed"
}

[sub_resource type="Resource" id="Rule_stable_order"]
script = ExtResource("3_rule")
rule_id = &"spatial_stable_order"
description = "SpatialIndex repeated sorted queries should produce stable order."
event_name = &"infrastructure.validation_probe"
required_core_values = {
"probe": &"spatial_stable_order",
"result": &"passed"
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"spatial_index_consistency_validation"
display_name = "Spatial Index Consistency Validation"
description = "Compares representative SpatialIndex queries against a full scan baseline."
goals = PackedStringArray("Verify lane/team/x filtering.", "Verify tag/kind filtering.", "Verify height_range overlap filtering.", "Verify repeated sorted queries are deterministic.")
validation_time_limit = 0.6
lane_count = 3
validation_rules = [SubResource("Rule_lane_team_x"), SubResource("Rule_tag_kind"), SubResource("Rule_height_range"), SubResource("Rule_stable_order")]
spawns = [SubResource("Spawn_source_wall"), SubResource("Spawn_lane_basic"), SubResource("Spawn_lane_fast"), SubResource("Spawn_off_lane"), SubResource("Spawn_air_scout")]
