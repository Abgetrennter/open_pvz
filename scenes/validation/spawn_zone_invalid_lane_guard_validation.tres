[gd_resource type="Resource" script_class="BattleScenario" load_steps=9 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battlefield_preset.gd" id="2_preset"]
[ext_resource type="Script" path="res://scripts/battle/spawn_zone_config.gd" id="3_zone"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="4_rule"]

[sub_resource type="Resource" id="SpawnZone_invalid"]
script = ExtResource("3_zone")
zone_id = &"invalid_lane_zone"
lane_id = 3
x = 700.0
zone_tags = PackedStringArray("spawn.medium.ground")

[sub_resource type="Resource" id="BattlefieldPreset_invalid_zone"]
script = ExtResource("2_preset")
preset_id = &"spawn_zone_invalid_lane_guard"
display_name = "Spawn Zone Invalid Lane Guard"
lane_count = 1
board_slot_count = 1
spawn_zones = [SubResource("SpawnZone_invalid")]

[sub_resource type="Resource" id="Rule_protocol_issue"]
script = ExtResource("4_rule")
rule_id = &"invalid_lane_protocol_issue"
description = "invalid spawn zone lane emits protocol.issue"
event_name = &"protocol.issue"
required_core_values = {
"scope": &"battle_scenario"
}

[sub_resource type="Resource" id="Rule_no_spawn"]
script = ExtResource("4_rule")
rule_id = &"no_wave_spawn"
description = "guardrail scenario has no wave spawn"
event_name = &"entity.spawned"
min_count = 0
max_count = 0
required_core_values = {
"spawn_reason": &"wave_spawn"
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"spawn_zone_invalid_lane_guard_validation"
display_name = "Spawn Zone Invalid Lane Guard Validation"
description = "Validates that spawn zones pointing outside lane_count are reported through protocol.issue."
validation_time_limit = 0.8
validation_fixed_step_count = 1
validation_finish_after_fixed_steps = true
battlefield_preset = SubResource("BattlefieldPreset_invalid_zone")
validation_rules = [SubResource("Rule_protocol_issue"), SubResource("Rule_no_spawn")]
