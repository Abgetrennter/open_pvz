[gd_resource type="Resource" script_class="BattleScenario" load_steps=6 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battle_spawn_entry.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="3_rule"]

[sub_resource type="Resource" id="Spawn_targeting_striker"]
script = ExtResource("2_spawn")
entity_kind = &"plant"
archetype_id = &"archetype_targeting_striker_skeleton"
lane_id = 0
x_position = 160.0
spawn_overrides = {
"amount": 20,
"interval": 0.4,
"scan_range": 900.0,
"start_delay": 0.2
}

[sub_resource type="Resource" id="Spawn_target_dummy"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_lane_dummy"
entity_template_id = &"zombie_lane_dummy"
lane_id = 0
x_position = 280.0
spawn_overrides = {
"max_health": 40
}

[sub_resource type="Resource" id="Rule_targeting_striker_spawned"]
script = ExtResource("3_rule")
rule_id = &"targeting_striker_spawned"
description = "targeting strik should spawn with archetype identity"
event_name = &"entity.spawned"
required_core_values = {
"target_archetype_id": &"archetype_targeting_striker_skeleton",
"target_template_id": &"plant_wall_barrier",
"target_kind": &"plant"
}

[sub_resource type="Resource" id="Rule_targeting_striker_damage"]
script = ExtResource("3_rule")
rule_id = &"targeting_striker_damage"
description = "independent targeting mechanic should compile into condition_values and enable correct detection and damage"
event_name = &"entity.damaged"
required_core_values = {
"source_archetype_id": &"archetype_targeting_striker_skeleton",
"target_template_id": &"zombie_lane_dummy",
"target_kind": &"zombie"
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"targeting_compile_validation"
display_name = "Targeting Compile Validation"
description = "Validates that an independent Targeting mechanic compiles its params into trigger condition_values and enables correct target detection and damage."
goals = PackedStringArray("Verify the Targeting mechanic's detection_id/scan_range inject into the compiled TriggerBinding condition_values.", "Verify the archetype detects and damages a target in the correct direction.")
validation_time_limit = 1.6
validation_rules = [SubResource("Rule_targeting_striker_spawned"), SubResource("Rule_targeting_striker_damage")]
spawns = [SubResource("Spawn_targeting_striker"), SubResource("Spawn_target_dummy")]
