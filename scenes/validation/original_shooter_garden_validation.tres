[resource]
script = ExtResource("1_scenario")
scenario_id = &"original_shooter_garden_validation"
display_name = "Original Shooter Garden Validation"
description = "Showcase: peashooter, repeater, gatlingpea, threepeater and splitpea each facing a row of zombies."
goals = PackedStringArray("Visual showcase of all original shooter plants in action.")
validation_time_limit = 10.0
lane_count = 5
validation_rules = [SubResource("Rule_tick")]
spawns = [SubResource("Spawn_peashooter"), SubResource("Spawn_walker_lane0"), SubResource("Spawn_repeater"), SubResource("Spawn_runner_lane1"), SubResource("Spawn_gatlingpea"), SubResource("Spawn_tank_lane2"), SubResource("Spawn_threepeater"), SubResource("Spawn_walker_lane2"), SubResource("Spawn_walker_lane3"), SubResource("Spawn_walker_lane4"), SubResource("Spawn_splitpea"), SubResource("Spawn_walker_behind"), SubResource("Spawn_runner_lane4")]
