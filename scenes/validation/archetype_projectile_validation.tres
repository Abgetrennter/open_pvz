[gd_resource type="Resource" script_class="BattleScenario" load_steps=6 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battle_spawn_entry.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="3_rule"]

[sub_resource type="Resource" id="Spawn_archetype_peashooter"]
script = ExtResource("2_spawn")
entity_kind = &"plant"
archetype_id = &"archetype_peashooter_skeleton"
lane_id = 0
x_position = 160.0
spawn_overrides = {
"interval": 0.5,
"scan_range": 900.0,
"speed": 320.0,
"start_delay": 0.2
}

[sub_resource type="Resource" id="Spawn_archetype_cabbage"]
script = ExtResource("2_spawn")
entity_kind = &"plant"
archetype_id = &"archetype_cabbage_skeleton"
lane_id = 1
x_position = 160.0
spawn_overrides = {
"interval": 0.7,
"scan_range": 900.0,
"speed": 260.0,
"start_delay": 0.2
}

[sub_resource type="Resource" id="Spawn_target_lane0"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_lane_dummy"
lane_id = 0
x_position = 320.0
spawn_overrides = {
"max_health": 40
}

[sub_resource type="Resource" id="Spawn_target_lane1"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_lane_dummy"
lane_id = 1
x_position = 360.0
spawn_overrides = {
"max_health": 80
}

[sub_resource type="Resource" id="Rule_pea_projectile_spawn"]
script = ExtResource("3_rule")
rule_id = &"pea_projectile_spawn"
description = "peashooter archetype should compile into a projectile-spawning runtime attack path"
event_name = &"projectile.spawned"
required_tags = PackedStringArray("projectile")
required_core_values = {
"profile_id": &"linear_ground",
"source_archetype_id": &"archetype_peashooter_skeleton",
}

[sub_resource type="Resource" id="Rule_pea_projectile_hit"]
script = ExtResource("3_rule")
rule_id = &"pea_projectile_hit"
description = "pea projectile spawned from the archetype path should hit the lane 0 dummy"
event_name = &"projectile.hit"
required_tags = PackedStringArray("projectile")
required_core_values = {
"source_archetype_id": &"archetype_peashooter_skeleton",
"target_archetype_id": &"archetype_lane_dummy",
"target_lane": 0
}

[sub_resource type="Resource" id="Rule_cabbage_projectile_spawn"]
script = ExtResource("3_rule")
rule_id = &"cabbage_projectile_spawn"
description = "cabbage archetype should compile into a parabola projectile attack path"
event_name = &"projectile.spawned"
required_tags = PackedStringArray("projectile")
required_core_values = {
"profile_id": &"parabola_cabbage_arc",
"source_archetype_id": &"archetype_cabbage_skeleton",
}

[sub_resource type="Resource" id="Rule_cabbage_projectile_hit"]
script = ExtResource("3_rule")
rule_id = &"cabbage_projectile_hit"
description = "cabbage projectile spawned from the archetype path should hit the lane 1 dummy"
event_name = &"projectile.hit"
required_tags = PackedStringArray("projectile")
required_core_values = {
"source_archetype_id": &"archetype_cabbage_skeleton",
"target_archetype_id": &"archetype_lane_dummy",
"target_lane": 1
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"archetype_projectile_validation"
display_name = "Archetype Projectile Validation"
description = "Validates that projectile-bearing archetypes can compile Trigger + Payload skeleton mechanics into the shared spawn_projectile runtime path for both linear and parabola attacks."
goals = PackedStringArray("Verify a peashooter archetype compiles into linear projectile spawning and hit events.", "Verify a cabbage archetype compiles into parabola projectile spawning and hit events.", "Verify both projectile paths preserve archetype identity in runtime events.")
validation_time_limit = 2.4
lane_count = 2
validation_rules = [SubResource("Rule_pea_projectile_spawn"), SubResource("Rule_pea_projectile_hit"), SubResource("Rule_cabbage_projectile_spawn"), SubResource("Rule_cabbage_projectile_hit")]
spawns = [SubResource("Spawn_archetype_peashooter"), SubResource("Spawn_archetype_cabbage"), SubResource("Spawn_target_lane0"), SubResource("Spawn_target_lane1")]
