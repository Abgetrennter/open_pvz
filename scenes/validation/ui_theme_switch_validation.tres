[gd_resource type="Resource" script_class="BattleScenario" load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="3_rule"]

[sub_resource type="Resource" id="Rule_theme_loaded"]
script = ExtResource("3_rule")
rule_id = &"theme_loaded"
description = "UIThemeProfile.default() should return a valid theme with expected fields"
event_name = &"visual.validation_probe"
required_tags = PackedStringArray("visual", "validation")
required_core_values = {
"probe": &"theme_default_loaded",
"result": &"passed"
}
min_count = 1

[resource]
script = ExtResource("1_scenario")
scenario_id = &"ui_theme_switch_validation"
display_name = "UI Theme Switch Validation"
description = "Verify UIThemeProfile.default() loads correctly and theme fields are accessible."
goals = PackedStringArray("Verify UIThemeProfile.default() returns a non-null profile.", "Verify theme contains expected color fields.", "Verify default theme values match expected defaults.")
validation_time_limit = 3.0
validation_rules = [SubResource("Rule_theme_loaded")]
