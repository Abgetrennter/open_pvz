initial_sun = 150
sun_auto_collect_delay = -1.0
sun_drop_entries = [SubResource("SunDrop_1"), SubResource("SunDrop_2"), SubResource("SunDrop_3"), SubResource("SunDrop_4"), SubResource("SunDrop_5"), SubResource("SunDrop_6"), SubResource("SunDrop_7"), SubResource("SunDrop_8")]
board_slot_count = 9
board_slot_origin_x = 200.0
board_slot_spacing = 80.0
lane_count = 5
card_defs = [ExtResource("2_card_sunflower"), ExtResource("3_card_shooter"), ExtResource("4_card_wall"), ExtResource("5_card_repeater"), ExtResource("6_card_lobber")]
wave_defs = [ExtResource("7_wave_1"), ExtResource("8_wave_2"), ExtResource("9_wave_3")]
field_object_configs = [SubResource("FieldObj_mower_0"), SubResource("FieldObj_mower_1"), SubResource("FieldObj_mower_2"), SubResource("FieldObj_mower_3"), SubResource("FieldObj_mower_4")]
defeat_line_x = 60.0
