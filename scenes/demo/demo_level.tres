[resource]
script = ExtResource("1_scenario")
scenario_id = &"demo_level"
display_name = "MVP Demo"
description = "A playable demo level with 5 lanes, 3 waves of zombies, and 5 plant cards."
goals = PackedStringArray("Collect sun and place plants to defend against 3 waves of zombies.", "Click a card to select, then click a grid cell to place.", "Press R to restart, Esc to return to menu.")
validation_time_limit = 120.0
initial_sun = 150
sun_auto_collect_delay = -1.0
sun_drop_entries = [SubResource("SunDrop_1"), SubResource("SunDrop_2"), SubResource("SunDrop_3"), SubResource("SunDrop_4"), SubResource("SunDrop_5"), SubResource("SunDrop_6"), SubResource("SunDrop_7"), SubResource("SunDrop_8")]
board_slot_count = 9
board_slot_origin_x = 200.0
board_slot_spacing = 80.0
lane_count = 5
card_defs = [SubResource("CardDef_sunflower"), SubResource("CardDef_shooter"), SubResource("CardDef_wall"), SubResource("CardDef_repeater"), SubResource("CardDef_lobber")]
wave_defs = [SubResource("WaveDef_1"), SubResource("WaveDef_2"), SubResource("WaveDef_3")]
field_object_configs = [SubResource("FieldObj_mower_0"), SubResource("FieldObj_mower_1"), SubResource("FieldObj_mower_2"), SubResource("FieldObj_mower_3"), SubResource("FieldObj_mower_4")]
defeat_line_x = 60.0
validation_rules = []
