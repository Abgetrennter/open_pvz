[resource]
script = ExtResource("1_scenario")
scenario_id = &"demo_level"
display_name = "MVP Demo"
description = "A playable demo level with 5 lanes, 3 waves of zombies, and 5 plant cards."
goals = PackedStringArray("Collect sun and place plants to defend against 3 waves of zombies.", "Click a card to select, then click a grid cell to place.", "Press R to restart, Esc to return to menu.")
