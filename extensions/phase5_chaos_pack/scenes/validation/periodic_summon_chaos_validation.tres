[gd_resource type="Resource" script_class="BattleScenario" load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/battle/battle_scenario.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/battle/battle_spawn_entry.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/battle/battle_validation_rule.gd" id="3_rule"]

[sub_resource type="Resource" id="Spawn_summoner"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_extension_summoner"
entity_template_id = &"plant_extension_summoner"
lane_id = 0
x_position = 160.0

[sub_resource type="Resource" id="Spawn_tank_target"]
script = ExtResource("2_spawn")
archetype_id = &"archetype_bucket_tank"
entity_template_id = &"zombie_bucket_tank"
lane_id = 0
x_position = 650.0

[sub_resource type="Resource" id="Rule_summoned_entities"]
script = ExtResource("3_rule")
rule_id = &"summoned_entities_spawned"
description = "extension spawn_entity should periodically summon shardlings through the shared spawn chain"
event_name = &"entity.spawned"
min_count = 2
required_core_values = {
"archetype_id": &"archetype_extension_shardling",
"source_template_id": &"plant_extension_summoner",
"spawn_reason": &"extension_summon"
}

[sub_resource type="Resource" id="Rule_summoned_damage"]
script = ExtResource("3_rule")
rule_id = &"summoned_entities_damage_target"
description = "summoned shardlings should damage the bucket tank through their own shared projectile runtime"
event_name = &"entity.damaged"
min_count = 1
required_core_values = {
"source_template_id": &"plant_extension_shardling",
"target_template_id": &"zombie_bucket_tank",
"value": 14
}

[sub_resource type="Resource" id="Rule_summoned_projectiles"]
script = ExtResource("3_rule")
rule_id = &"summoned_entities_fire_projectiles"
description = "summoned shardlings should spawn their own projectiles after being created"
event_name = &"projectile.spawned"
min_count = 1
required_tags = PackedStringArray("projectile")
required_core_values = {
"source_template_id": &"plant_extension_shardling",
"target_template_id": &"pea_linear"
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"periodic_summon_chaos_validation"
display_name = "Periodic Summon Chaos Validation"
description = "Validates the first extension-backed periodic summon chaos sample: a summoner periodically spawns shardlings, and the summoned plants immediately join the shared attack runtime."
goals = PackedStringArray("Verify the extension spawn_entity effect periodically creates shardlings.", "Verify summoned shardlings enter the same runtime entity spawn chain as built-in content.", "Verify summoned shardlings fire projectiles and damage the target tank without BattleManager-specific summon scripts.")
validation_time_limit = 3.6
validation_rules = [SubResource("Rule_summoned_entities"), SubResource("Rule_summoned_projectiles"), SubResource("Rule_summoned_damage")]
spawns = [SubResource("Spawn_summoner"), SubResource("Spawn_tank_target")]


