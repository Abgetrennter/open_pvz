param_defs = [{
"name": "impact_damage",
"type": "int",
"min": 0,
"max": 9999,
"default": 0
}, {
"name": "damage",
"type": "int",
"min": 0,
"max": 9999,
"default": 12
}, {
"name": "speed",
"type": "float",
"min": 1.0,
"max": 12000.0,
"default": 260.0
}, {
"name": "movement_mode",
"type": "string_name",
"default": &"track",
"options": PackedStringArray("linear", "track", "parabola")
}, {
"name": "turn_rate",
"type": "float",
"min": 0.0,
"max": 30.0,
"default": 8.0
}, {
"name": "search_radius",
"type": "float",
"min": 1.0,
"max": 1500.0,
"default": 260.0
}, {
"name": "max_targets",
"type": "int",
"min": 1,
"max": 4,
"default": 2
}, {
"name": "projectile_template",
"type": "resource",
"resource_script": "res://scripts/core/defs/projectile_template.gd"
}, {
"name": "flight_profile",
"type": "resource",
"resource_script": "res://scripts/projectile/projectile_flight_profile.gd"
}]
