[ext_resource type="Script" path="res://scripts/core/defs/effect_slot_def.gd" id="3_slot"]

[sub_resource type="Resource" id="EffectSlot_on_hit"]
script = ExtResource("3_slot")
slot_name = &"on_hit"
slot_type = 1
allowed_effect_tags = PackedStringArray("hit_response")

[resource]
script = ExtResource("1_effect")
